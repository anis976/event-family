{% extends 'base.html.twig' %}

{% block title %}RapproFam — {{ ef_group_name(group) }}{% endblock %}
{% block meta_description %}
    {% include 'components/_ef_meta_description.html.twig' with {
        key: 'ui.groups.show.meta_description',
        parameters: { '%name%': ef_group_name(group) },
    } only %}
{% endblock %}
{% block page_title %}{{ ef_group_name(group) }}{% endblock %}

{% block body %}
<div class="container py-5 ef-GroupShow">
    <h1 class="visually-hidden">{{ ef_group_name(group) }}</h1>

    <nav aria-label="{{ 'ui.groups.breadcrumb_aria'|trans }}" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item ef-GroupShow__nav-link">
                <a href="{{ path('app_groups') }}">{{ isMember ? 'ui.groups.show.my_groups_breadcrumb'|trans : 'ui.groups.breadcrumb'|trans }}</a>
            </li>
            <li class="breadcrumb-item active ef-GroupShow__nav-link" aria-current="page">{{ ef_group_name(group) }}</li>
        </ol>
    </nav>

    {% if isStaffCircle and isSiteStaff %}
        <div class="d-flex flex-wrap gap-2 mb-4 ef-GroupShow__staff-actions">
            <a href="{{ path('app_messages_group', { groupId: group.id }) }}" class="btn ef-GroupShow__btn-edit">
                <i class="bi bi-megaphone me-2" aria-hidden="true"></i> {{ 'ui.groups.show.group_messages'|trans }}
            </a>
        </div>
    {% elseif isStaff or isSiteStaff %}
        {% if not isStaffCircle %}
        <div class="d-flex flex-wrap gap-2 mb-4 ef-GroupShow__staff-actions">
            {% if isStaff %}
                <a href="{{ path('app_groups_manage_requests', { id: group.id }) }}" class="btn ef-GroupShow__btn-edit"{% if pendingRequestsCount > 0 %} aria-label="{{ 'ui.groups.show.manage_requests_aria'|trans({'%count%': pendingRequestsCount}) }}"{% endif %}>
                    <i class="bi bi-inbox me-2" aria-hidden="true"></i> {{ 'ui.groups.show.manage_requests'|trans }}
                    {% if pendingRequestsCount > 0 %}
                        <span class="badge bg-danger ms-1" aria-hidden="true">{{ pendingRequestsCount }}</span>
                    {% endif %}
                </a>
                <a href="{{ path('app_groups_invite_search', { id: group.id }) }}" class="btn ef-GroupShow__btn-edit">
                    <i class="bi bi-person-plus me-2" aria-hidden="true"></i> {{ 'ui.groups.show.invite_members'|trans }}
                </a>
            {% endif %}
            {% if isSiteStaff %}
                <a href="{{ path('app_messages_group', { groupId: group.id }) }}" class="btn ef-GroupShow__btn-edit">
                    <i class="bi bi-megaphone me-2" aria-hidden="true"></i> {{ 'ui.groups.show.group_messages'|trans }}
                </a>
            {% endif %}
        </div>
        {% endif %}
    {% endif %}

    {% if isStaffCircle %}
        <div class="alert alert-info border-0 shadow-sm mb-4 ef-GroupShow__staff-circle-notice" role="status">
            <div class="d-flex gap-3">
                <i class="bi bi-info-circle-fill fs-4 flex-shrink-0" aria-hidden="true"></i>
                <div>
                    <p class="fw-bold mb-1">{{ 'ui.groups.staff_circle.purpose_title'|trans }}</p>
                    <p class="mb-0 small">{{ 'ui.groups.staff_circle.purpose_body'|trans }}</p>
                    {% if not isMember %}
                        <p class="mb-0 mt-2 small text-muted">{{ 'ui.groups.staff_circle.members_only_hint'|trans }}</p>
                    {% endif %}
                </div>
            </div>
        </div>
    {% endif %}

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm ef-card-info p-3 sticky-top ef-GroupShow__info-card">
                <div class="card-body ef-GroupShow__card-body">
                    {% if isMember and isOwner %}
                        <span class="badge mb-2 px-3 ef-badge-role-chef">{{ 'ui.groups.show.role_owner'|trans }}</span>
                    {% elseif isMember and isModerator %}
                        <span class="badge mb-2 px-3 ef-badge-role-modo"><i class="bi bi-shield-check me-1" aria-hidden="true"></i>{{ 'ui.groups.show.role_moderator'|trans }}</span>
                    {% endif %}

                    <p class="ef-GroupShow__family-text mb-2">{{ ef_group_family_name(group) }}</p>
                    <p class="ef-GroupShow__group-name h4 mb-1">{{ ef_group_name(group) }}</p>
                    <p class="mb-4 ef-GroupShow__createdAt">{{ 'ui.groups.show.created_on'|trans({'%date%': group.createdAt|ef_date}) }}</p>
                    <hr class="opacity-10">

                    <div class="mb-4">
                        <h3 class="text-uppercase text-muted small h6">{{ 'ui.common.description'|trans }}</h3>
                        <p class="ef-GroupShow__desc-full">{{ ef_group_description(group)|default('ui.common.no_description'|trans) }}</p>
                    </div>

                    {% if isMember and isOwner %}
                        <a href="{{ path('app_groups_edit', { id: group.id }) }}" class="btn w-100 ef-GroupShow__btn-edit">
                            <i class="bi bi-pencil-square me-2" aria-hidden="true"></i>{{ 'ui.groups.show.edit_info'|trans }}
                        </a>
                    {% endif %}

                    {% if isMember and can_leave_group|default(false) %}
                        {% if has_stale_owner_role|default(false) %}
                            <div class="alert alert-warning border-0 small py-2 mb-2" role="status">
                                {{ 'ui.groups.show.stale_owner_role_notice'|trans }}
                            </div>
                        {% endif %}
                        {% if isOwner and owner_is_sole_member|default(false) %}
                            <button type="button" class="btn w-100 btn-outline-danger{% if isOwner %} mt-2{% endif %}" data-bs-toggle="modal" data-bs-target="#leave-group-dissolve-modal">
                                <i class="bi bi-box-arrow-right me-2" aria-hidden="true"></i>{{ 'ui.groups.show.leave_dissolve'|trans }}
                            </button>
                        {% elseif isOwner and leave_successor_candidates is not empty %}
                            <button type="button" class="btn w-100 btn-outline-danger mt-2" data-bs-toggle="modal" data-bs-target="#leave-group-owner-modal">
                                <i class="bi bi-box-arrow-right me-2" aria-hidden="true"></i>{{ 'ui.groups.show.leave_group'|trans }}
                            </button>
                        {% elseif isOwner and owner_has_other_members|default(false) %}
                            <div class="alert alert-warning border-0 small py-2 mb-0 mt-2" role="status">
                                {{ 'ui.groups.show.leave_no_successor'|trans }}
                            </div>
                        {% elseif not isOwner %}
                            <button type="button" class="btn w-100 btn-outline-danger{% if isOwner %} mt-2{% endif %}" data-bs-toggle="modal" data-bs-target="#leave-group-modal">
                                <i class="bi bi-box-arrow-right me-2" aria-hidden="true"></i>{{ 'ui.groups.show.leave_group'|trans }}
                            </button>
                        {% endif %}
                    {% elseif not isMember %}
                        <div class="ef-GroupShow__join-box">
                            {% if joinState.state == 'invited' and joinState.request %}
                                <p class="small text-muted mb-3">{{ 'ui.groups.show.invitation_received'|trans }}</p>
                                <div class="d-flex flex-column gap-2">
                                    <form action="{{ path('app_groups_accept_invitation', { id: group.id, requestId: joinState.request.id }) }}" method="POST" data-turbo="false">
                                        <input type="hidden" name="_token" value="{{ csrf_token('accept-invitation' ~ joinState.request.id) }}">
                                        <button type="submit" class="btn btn-save-profile w-100 py-2 fw-bold">
                                            <i class="bi bi-check-lg me-2" aria-hidden="true"></i> {{ 'ui.groups.show.accept_invitation'|trans }}
                                        </button>
                                    </form>
                                    <form action="{{ path('app_groups_refuse_invitation', { id: group.id, requestId: joinState.request.id }) }}" method="POST" data-turbo="false">
                                        <input type="hidden" name="_token" value="{{ csrf_token('refuse-invitation' ~ joinState.request.id) }}">
                                        <button type="submit" class="btn ef-groups-form__btn-cancel w-100 py-2">
                                            {{ 'ui.groups.show.refuse_invitation'|trans }}
                                        </button>
                                    </form>
                                </div>
                            {% elseif joinState.state == 'pending' %}
                                <button type="button" class="btn btn-secondary w-100 py-2" disabled>
                                    <i class="bi bi-hourglass-split me-2" aria-hidden="true"></i> {{ 'ui.groups.show.request_pending'|trans }}
                                </button>
                    {% elseif joinState.state == 'blocked' %}
                        <div class="alert alert-danger mb-0 small">
                            <i class="bi bi-slash-circle me-1" aria-hidden="true"></i>
                            {{ 'ui.groups.show.join_blocked'|trans }}
                        </div>
                    {% elseif joinState.state == 'staff_circle' %}
                        <div class="alert alert-secondary mb-0 small">
                            <i class="bi bi-shield-lock me-1" aria-hidden="true"></i>
                            {{ 'ui.groups.staff_circle.no_join'|trans }}
                        </div>
                    {% elseif joinState.state == 'available' %}
                                <form action="{{ path('app_groups_request_join', { id: group.id }) }}" method="POST" data-turbo="false">
                                    <input type="hidden" name="_token" value="{{ csrf_token('join-group' ~ group.id) }}">
                                    <button type="submit" class="btn btn-save-profile w-100 py-2 fw-bold">
                                        <i class="bi bi-door-open me-2" aria-hidden="true"></i> {{ 'ui.groups.show.request_join'|trans }}
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            {% if isMember or isStaffCircle %}
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                        <h3 class="h5 fw-bold mb-0">
                            {% if isStaffCircle %}
                                {{ 'ui.groups.staff_circle.shared_events'|trans }}
                            {% else %}
                                {{ 'ui.groups.show.group_events'|trans }}
                            {% endif %}
                        </h3>
                        <div class="d-flex flex-wrap gap-2">
                            {% if can_create_event %}
                                <a href="{{ path('app_events_new', { groupe: group.id }) }}" class="btn btn-sm ef-GroupShow__btn-edit" data-turbo="false">
                                    <i class="bi bi-plus-lg me-1" aria-hidden="true"></i> {{ 'ui.common.create'|trans }}
                                </a>
                            {% endif %}
                            <a href="{{ path('app_events') }}" class="btn btn-sm ef-btn-viewAllEvent rounded-pill px-3" data-turbo="false">
                                {{ 'ui.common.view_all'|trans }} <i class="bi bi-chevron-right ms-1" aria-hidden="true"></i>
                            </a>
                        </div>
                    </div>

                    {% if is_regular_member %}
                        <div class="alert alert-info border-0 small py-2 mb-3" role="status">
                            {{ 'ui.groups.show.member_event_notice'|trans }}
                        </div>
                    {% endif %}

                    {% if groupEventsOngoing is not empty %}
                        <h4 class="h6 text-muted text-uppercase mb-2">{{ 'ui.groups.show.filter_ongoing'|trans }}</h4>
                        <div class="row row-cols-1 row-cols-md-2 g-3 mb-4">
                            {% for event in groupEventsOngoing %}
                                {% include 'events/_article_card.html.twig' with { event: event, is_past: false, use_modal: false } %}
                            {% endfor %}
                        </div>
                    {% endif %}

                    {% if groupEventsUpcoming is not empty %}
                        <h4 class="h6 text-muted text-uppercase mb-2">{{ 'ui.groups.show.filter_upcoming'|trans }}</h4>
                        <div class="row row-cols-1 row-cols-md-2 g-3 mb-4">
                            {% for event in groupEventsUpcoming %}
                                {% include 'events/_article_card.html.twig' with { event: event, is_past: false, use_modal: false } %}
                            {% endfor %}
                        </div>
                    {% elseif groupEventsOngoing is empty %}
                        {% include 'events/_empty.html.twig' with {
                            message: isStaffCircle
                                ? 'ui.groups.staff_circle.no_shared_events'|trans
                                : 'ui.groups.show.no_group_events'|trans
                        } %}
                    {% endif %}
                </div>
            {% endif %}

            {% include 'groups/_members_table.html.twig' with { hide_moderation: isStaffCircle } %}
        </div>
    </div>
</div>

{% if can_leave_group|default(false) %}
    {% if not isOwner %}
        <div class="modal fade" id="leave-group-modal" tabindex="-1" aria-labelledby="leave-group-modal-label" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <form action="{{ path('app_groups_leave', { id: group.id }) }}" method="POST" data-turbo="false">
                        <input type="hidden" name="_token" value="{{ csrf_token('leave-group' ~ group.id) }}">
                        <div class="modal-header border-0">
                            <h5 class="modal-title" id="leave-group-modal-label">{{ 'ui.groups.leave.modal_title'|trans }}</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'ui.common.close'|trans }}"></button>
                        </div>
                        <div class="modal-body">
                            <p class="text-muted small mb-0">{{ 'ui.groups.leave.modal_hint'|trans }}</p>
                        </div>
                        <div class="modal-footer border-0">
                            <button type="button" class="btn ef-groups-form__btn-cancel px-4" data-bs-dismiss="modal">{{ 'ui.common.cancel'|trans }}</button>
                            <button type="submit" class="btn btn-danger">{{ 'ui.groups.leave.confirm'|trans }}</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    {% elseif owner_is_sole_member|default(false) %}
        <div class="modal fade" id="leave-group-dissolve-modal" tabindex="-1" aria-labelledby="leave-group-dissolve-modal-label" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <form action="{{ path('app_groups_leave', { id: group.id }) }}" method="POST" data-turbo="false">
                        <input type="hidden" name="_token" value="{{ csrf_token('leave-group' ~ group.id) }}">
                        <div class="modal-header border-0">
                            <h5 class="modal-title" id="leave-group-dissolve-modal-label">{{ 'ui.groups.leave.dissolve_modal_title'|trans }}</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'ui.common.close'|trans }}"></button>
                        </div>
                        <div class="modal-body">
                            <p class="text-muted small mb-0">{{ 'ui.groups.leave.dissolve_modal_hint'|trans }}</p>
                        </div>
                        <div class="modal-footer border-0">
                            <button type="button" class="btn ef-groups-form__btn-cancel px-4" data-bs-dismiss="modal">{{ 'ui.common.cancel'|trans }}</button>
                            <button type="submit" class="btn btn-danger">{{ 'ui.groups.leave.dissolve_confirm'|trans }}</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    {% elseif leave_successor_candidates is not empty %}
        <div class="modal fade" id="leave-group-owner-modal" tabindex="-1" aria-labelledby="leave-group-owner-modal-label" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <form action="{{ path('app_groups_leave', { id: group.id }) }}" method="POST" data-turbo="false">
                        <input type="hidden" name="_token" value="{{ csrf_token('leave-group' ~ group.id) }}">
                        <div class="modal-header border-0">
                            <h5 class="modal-title" id="leave-group-owner-modal-label">{{ 'ui.groups.leave.owner_modal_title'|trans }}</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'ui.common.close'|trans }}"></button>
                        </div>
                        <div class="modal-body">
                            <p class="text-muted small mb-3">{{ 'ui.groups.leave.owner_modal_hint'|trans }}</p>
                            <label for="leave-successor-id" class="form-label fw-medium">{{ 'ui.groups.leave.successor_label'|trans }} <span class="text-danger">*</span></label>
                            <select id="leave-successor-id" name="successor_id" class="form-select ef-input mb-3" required>
                                <option value="">{{ 'ui.groups.leave.successor_placeholder'|trans }}</option>
                                {% for candidate in leave_successor_candidates %}
                                    {% set candidate_user = candidate.user %}
                                    <option value="{{ candidate_user.id }}">
                                        {{ candidate_user.firstName|capitalize }} {{ candidate_user.lastName|upper }}
                                        {% if candidate.role.value == 'MODERATOR' %} ({{ 'ui.groups.members.role_moderator'|trans }}){% endif %}
                                    </option>
                                {% endfor %}
                            </select>
                            <label for="leave-current-password" class="form-label fw-medium">{{ 'ui.profile.form.label.current_password'|trans }} <span class="text-danger">*</span></label>
                            <input
                                type="password"
                                id="leave-current-password"
                                name="current_password"
                                class="form-control ef-input"
                                autocomplete="current-password"
                                required
                                placeholder="{{ 'ui.auth.placeholder.password_current'|trans }}"
                            >
                        </div>
                        <div class="modal-footer border-0">
                            <button type="button" class="btn ef-groups-form__btn-cancel px-4" data-bs-dismiss="modal">{{ 'ui.common.cancel'|trans }}</button>
                            <button type="submit" class="btn btn-danger">{{ 'ui.groups.leave.owner_confirm'|trans }}</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    {% endif %}
{% endif %}
{% endblock %}
