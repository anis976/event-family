{% extends 'base.html.twig' %}

{% block title %}RapproFam — {{ group.name }}{% endblock %}
{% block page_title %}{{ group.name }}{% endblock %}

{% block body %}
<div class="container py-5 ef-GroupShow">
    <h1 class="visually-hidden">{{ group.name }}</h1>

    <nav aria-label="{{ 'ui.groups.breadcrumb_aria'|trans }}" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item ef-GroupShow__nav-link">
                <a href="{{ path('app_groups') }}">{{ isMember ? 'ui.groups.show.my_groups_breadcrumb'|trans : 'ui.groups.breadcrumb'|trans }}</a>
            </li>
            <li class="breadcrumb-item active ef-GroupShow__nav-link" aria-current="page">{{ group.name }}</li>
        </ol>
    </nav>

    {% if isStaff or isSiteStaff %}
        <div class="d-flex flex-wrap gap-2 mb-4 ef-GroupShow__staff-actions">
            {% if isStaff %}
                <a href="{{ path('app_groups_manage_requests', { id: group.id }) }}" class="btn ef-GroupShow__btn-edit"{% if pendingRequestsCount > 0 %} aria-label="{{ 'ui.groups.show.manage_requests_aria'|trans({'%count%': pendingRequestsCount}) }}"{% endif %}>
                    <i class="bi bi-inbox me-2" aria-hidden="true"></i> {{ 'ui.groups.show.manage_requests'|trans }}
                    {% if pendingRequestsCount > 0 %}
                        <span class="badge bg-danger ms-1" aria-hidden="true">{{ pendingRequestsCount }}</span>
                    {% endif %}
                </a>
                <a href="{{ path('app_groups_invite_search', { id: group.id }) }}" class="btn ef-GroupShow__btn-edit">
                    <i class="bi bi-person-plus me-2" aria-hidden="true"></i> {{ 'ui.groups.show.invite_members'|trans }}
                </a>
            {% endif %}
            {% if isSiteStaff %}
                <a href="{{ path('app_messages_group', { groupId: group.id }) }}" class="btn ef-GroupShow__btn-edit">
                    <i class="bi bi-megaphone me-2" aria-hidden="true"></i> {{ 'ui.groups.show.group_messages'|trans }}
                </a>
            {% endif %}
        </div>
    {% endif %}

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm ef-card-info p-3 sticky-top ef-GroupShow__info-card">
                <div class="card-body ef-GroupShow__card-body">
                    {% if isMember and isOwner %}
                        <span class="badge mb-2 px-3 ef-badge-role-chef">{{ 'ui.groups.show.role_owner'|trans }}</span>
                    {% elseif isMember and isModerator %}
                        <span class="badge mb-2 px-3 ef-badge-role-modo"><i class="bi bi-shield-check me-1" aria-hidden="true"></i>{{ 'ui.groups.show.role_moderator'|trans }}</span>
                    {% endif %}

                    <p class="ef-GroupShow__family-text mb-2">{{ group.familyName }}</p>
                    <p class="ef-GroupShow__group-name h4 mb-1">{{ group.name }}</p>
                    <p class="mb-4 ef-GroupShow__createdAt">{{ 'ui.groups.show.created_on'|trans({'%date%': group.createdAt|ef_date}) }}</p>
                    <hr class="opacity-10">

                    <div class="mb-4">
                        <h3 class="text-uppercase text-muted small h6">{{ 'ui.common.description'|trans }}</h3>
                        <p class="ef-GroupShow__desc-full">{{ group.description|default('ui.common.no_description'|trans) }}</p>
                    </div>

                    {% if isMember and isOwner %}
                        <a href="{{ path('app_groups_edit', { id: group.id }) }}" class="btn w-100 ef-GroupShow__btn-edit">
                            <i class="bi bi-pencil-square me-2" aria-hidden="true"></i>{{ 'ui.groups.show.edit_info'|trans }}
                        </a>
                    {% elseif not isMember %}
                        <div class="ef-GroupShow__join-box">
                            {% if joinState.state == 'invited' and joinState.request %}
                                <p class="small text-muted mb-3">{{ 'ui.groups.show.invitation_received'|trans }}</p>
                                <div class="d-flex flex-column gap-2">
                                    <form action="{{ path('app_groups_accept_invitation', { id: group.id, requestId: joinState.request.id }) }}" method="POST" data-turbo="false">
                                        <input type="hidden" name="_token" value="{{ csrf_token('accept-invitation' ~ joinState.request.id) }}">
                                        <button type="submit" class="btn btn-save-profile w-100 py-2 fw-bold">
                                            <i class="bi bi-check-lg me-2" aria-hidden="true"></i> {{ 'ui.groups.show.accept_invitation'|trans }}
                                        </button>
                                    </form>
                                    <form action="{{ path('app_groups_refuse_invitation', { id: group.id, requestId: joinState.request.id }) }}" method="POST" data-turbo="false">
                                        <input type="hidden" name="_token" value="{{ csrf_token('refuse-invitation' ~ joinState.request.id) }}">
                                        <button type="submit" class="btn ef-groups-form__btn-cancel w-100 py-2">
                                            {{ 'ui.groups.show.refuse_invitation'|trans }}
                                        </button>
                                    </form>
                                </div>
                            {% elseif joinState.state == 'pending' %}
                                <button type="button" class="btn btn-secondary w-100 py-2" disabled>
                                    <i class="bi bi-hourglass-split me-2" aria-hidden="true"></i> {{ 'ui.groups.show.request_pending'|trans }}
                                </button>
                            {% elseif joinState.state == 'blocked' %}
                                <div class="alert alert-danger mb-0 small">
                                    <i class="bi bi-slash-circle me-1" aria-hidden="true"></i>
                                    {{ 'ui.groups.show.join_blocked'|trans }}
                                </div>
                            {% elseif joinState.state == 'available' %}
                                <form action="{{ path('app_groups_request_join', { id: group.id }) }}" method="POST" data-turbo="false">
                                    <input type="hidden" name="_token" value="{{ csrf_token('join-group' ~ group.id) }}">
                                    <button type="submit" class="btn btn-save-profile w-100 py-2 fw-bold">
                                        <i class="bi bi-door-open me-2" aria-hidden="true"></i> {{ 'ui.groups.show.request_join'|trans }}
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            {% if isMember %}
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                        <h3 class="h5 fw-bold mb-0">{{ 'ui.groups.show.group_events'|trans }}</h3>
                        <div class="d-flex flex-wrap gap-2">
                            {% if can_create_event %}
                                <a href="{{ path('app_events_new', { groupe: group.id }) }}" class="btn btn-sm ef-GroupShow__btn-edit" data-turbo="false">
                                    <i class="bi bi-plus-lg me-1" aria-hidden="true"></i> {{ 'ui.common.create'|trans }}
                                </a>
                            {% endif %}
                            <a href="{{ path('app_events') }}" class="btn btn-sm ef-btn-viewAllEvent rounded-pill px-3" data-turbo="false">
                                {{ 'ui.common.view_all'|trans }} <i class="bi bi-chevron-right ms-1" aria-hidden="true"></i>
                            </a>
                        </div>
                    </div>

                    {% if is_regular_member %}
                        <div class="alert alert-info border-0 small py-2 mb-3" role="status">
                            {{ 'ui.groups.show.member_event_notice'|trans }}
                        </div>
                    {% endif %}

                    {% if groupEventsOngoing is not empty %}
                        <h4 class="h6 text-muted text-uppercase mb-2">{{ 'ui.groups.show.filter_ongoing'|trans }}</h4>
                        <div class="row row-cols-1 row-cols-md-2 g-3 mb-4">
                            {% for event in groupEventsOngoing %}
                                {% include 'events/_article_card.html.twig' with { event: event, is_past: false, use_modal: false } %}
                            {% endfor %}
                        </div>
                    {% endif %}

                    {% if groupEventsUpcoming is not empty %}
                        <h4 class="h6 text-muted text-uppercase mb-2">{{ 'ui.groups.show.filter_upcoming'|trans }}</h4>
                        <div class="row row-cols-1 row-cols-md-2 g-3 mb-4">
                            {% for event in groupEventsUpcoming %}
                                {% include 'events/_article_card.html.twig' with { event: event, is_past: false, use_modal: false } %}
                            {% endfor %}
                        </div>
                    {% elseif groupEventsOngoing is empty %}
                        {% include 'events/_empty.html.twig' with { message: 'ui.groups.show.no_group_events'|trans } %}
                    {% endif %}
                </div>
            {% endif %}

            {% include 'groups/_members_table.html.twig' %}
        </div>
    </div>
</div>
{% endblock %}
