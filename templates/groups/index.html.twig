{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.groups.page_title'|trans }}{% endblock %}
{% set meta_description_key = 'ui.groups.meta_description' %}
{% block page_title %}{{ 'ui.groups.title'|trans }}{% endblock %}

{% block body %}
<div class="ef-main-content-padding ef-groups">
    <h1 class="visually-hidden">{{ 'ui.groups.title'|trans }}</h1>

    {% if staffCircle %}
        <section class="mb-5 ef-groups__staff-circle-section" aria-labelledby="staff-circle-heading">
            <div class="d-flex justify-content-between align-items-center mb-3 ef-groups__title">
                <h2 id="staff-circle-heading" class="mb-0">{{ 'ui.groups.staff_circle.section_title'|trans }}</h2>
            </div>
            <div class="row row-cols-1 g-4">
                {% include 'groups/_group_card.html.twig' with {
                    group: staffCircle,
                    card_href: path('app_groups_show', { id: staffCircle.id }),
                    member_count: member_counts[staffCircle.id]|default(0),
                    is_staff_circle: true,
                    is_staff_circle_member: is_staff_circle_member,
                } %}
            </div>
        </section>
    {% endif %}

    <div class="d-flex justify-content-between align-items-center mb-4 ef-groups__title">
        <h2 class="mb-0">{{ 'ui.groups.my_groups'|trans }}</h2>
        {% if can_create %}
            <a href="{{ path('app_groups_new') }}" class="btn btn-save-profile px-4 py-2 fw-bold shadow-sm">
                <i class="bi bi-plus-lg me-1" aria-hidden="true"></i> {{ 'ui.groups.create'|trans }}
            </a>
        {% endif %}
    </div>

    {% if myGroups is empty %}
        <div class="card mb-5 ef-groups__empty border-dashed border-2 text-center py-5">
            <div class="card-body">
                <i class="bi bi-people fs-1 text-muted mb-3 d-block" aria-hidden="true"></i>
                <p class="text-muted mb-0">{{ 'ui.groups.empty_my'|trans }}</p>
                {% if can_create %}
                    <a href="{{ path('app_groups_new') }}" class="btn btn-save-profile px-4 py-2 fw-bold shadow-sm mt-3">
                        <i class="bi bi-plus-lg me-1" aria-hidden="true"></i> {{ 'ui.groups.create_first'|trans }}
                    </a>
                {% endif %}
            </div>
        </div>
    {% else %}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-4">
            {% for group in myGroups %}
                {% include 'groups/_group_card.html.twig' with {
                    group: group,
                    card_href: path('app_groups_show', { id: group.id }),
                    member_count: member_counts[group.id]|default(0),
                } %}
            {% endfor %}
        </div>

        {% include 'components/_ef_paginate.html.twig' with {
            pagination: myGroupsPagination,
            route_name: 'app_groups',
            route_params: app.request.query.get('page') ? { page: app.request.query.getInt('page') } : {},
            page_param: 'page_my',
            wrapper_class: 'd-flex justify-content-center ef-paginate mt-2 mb-5',
            aria_label: 'ui.groups.pagination_my_aria'|trans,
        } %}
    {% endif %}

    {% include 'components/_ef_adsense_unit.html.twig' with { slot: ef_google_adsense_slot_groups } only %}

    <div class="d-flex justify-content-between align-items-center mb-4 ef-groups__title">
        <h2 class="mb-0">{{ 'ui.groups.all_groups'|trans }}</h2>
    </div>

    {% if otherGroups is empty %}
        <div class="card ef-groups__empty border-dashed border-2 text-center py-5">
            <div class="card-body">
                <p class="text-muted mb-0">{{ 'ui.groups.empty_others'|trans }}</p>
            </div>
        </div>
    {% else %}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for group in otherGroups %}
                {% include 'groups/_group_card.html.twig' with {
                    group: group,
                    card_href: path('app_groups_show', { id: group.id }),
                    member_count: member_counts[group.id]|default(0),
                } %}
            {% endfor %}
        </div>

        {% include 'components/_ef_paginate.html.twig' with {
            pagination: othersPagination,
            route_name: 'app_groups',
            route_params: app.request.query.get('page_my') ? { page_my: app.request.query.getInt('page_my') } : {},
            wrapper_class: 'd-flex justify-content-center ef-paginate mt-5',
            aria_label: 'ui.groups.pagination_others_aria'|trans,
        } %}
    {% endif %}
</div>
{% endblock %}
