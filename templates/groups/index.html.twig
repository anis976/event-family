{% extends 'base.html.twig' %}

{% block title %}EventFamily — Groupes{% endblock %}
{% block page_title %}Groupes{% endblock %}

{% block body %}
<div class="ef-main-content-padding ef-groups">
    <div class="d-flex justify-content-between align-items-center mb-4 ef-groups__title">
        <h2 class="mb-0">Mes groupes</h2>
        {% if can_create %}
            <a href="{{ path('app_groups_new') }}" class="btn btn-save-profile px-4 py-2 fw-bold shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> Créer un groupe
            </a>
        {% endif %}
    </div>

    {% if myGroups is empty %}
        <div class="card mb-5 ef-groups__empty border-dashed border-2 text-center py-5">
            <div class="card-body">
                <i class="bi bi-people fs-1 text-muted mb-3 d-block"></i>
                <p class="text-muted mb-0">Tu n'appartiens à aucun groupe pour le moment.</p>
                {% if can_create %}
                    <a href="{{ path('app_groups_new') }}" class="btn btn-save-profile px-4 py-2 fw-bold shadow-sm mt-3">
                        <i class="bi bi-plus-lg me-1"></i> Créer mon premier groupe
                    </a>
                {% endif %}
            </div>
        </div>
    {% else %}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">
            {% for group in myGroups %}
                {% include 'groups/_group_card.html.twig' with {
                    group: group,
                    card_href: path('app_groups_show', { id: group.id }),
                } %}
            {% endfor %}
        </div>
    {% endif %}

    <div class="d-flex justify-content-between align-items-center mb-4 ef-groups__title">
        <h2 class="mb-0">Tous les groupes</h2>
    </div>

    {% if otherGroups is empty %}
        <div class="card ef-groups__empty border-dashed border-2 text-center py-5">
            <div class="card-body">
                <p class="text-muted mb-0">Aucun autre groupe à découvrir pour le moment.</p>
            </div>
        </div>
    {% else %}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for group in otherGroups %}
                {% include 'groups/_group_card.html.twig' with {
                    group: group,
                    card_href: path('app_groups_show', { id: group.id }),
                } %}
            {% endfor %}
        </div>

        {% include 'components/_ef_paginate.html.twig' with {
            pagination: pagination,
            route_name: 'app_groups',
            route_params: {},
        } %}
    {% endif %}
</div>
{% endblock %}
