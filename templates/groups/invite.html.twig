{% extends 'base.html.twig' %}

{% block title %}EventFamily — Inviter — {{ group.name }}{% endblock %}
{% block page_title %}Inviter des membres{% endblock %}

{% block body %}
<div class="container py-5 ef-GroupShow">
    <nav aria-label="Fil d'Ariane" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item ef-GroupShow__nav-link"><a href="{{ path('app_groups') }}">Mes groupes</a></li>
            <li class="breadcrumb-item ef-GroupShow__nav-link"><a href="{{ path('app_groups_show', { id: group.id }) }}">{{ group.name }}</a></li>
            <li class="breadcrumb-item active ef-GroupShow__nav-link" aria-current="page">Inviter</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-3">Rechercher un membre</h2>
            <form method="GET" action="{{ path('app_groups_invite_search', { id: group.id }) }}" class="d-flex gap-2">
                <input
                    type="search"
                    name="q"
                    class="form-control ef-input"
                    value="{{ searchQuery }}"
                    placeholder="Prénom, nom, pseudo ou e-mail…"
                    minlength="2"
                >
                <button type="submit" class="btn btn-save-profile px-4 fw-bold">
                    <i class="bi bi-search me-1"></i> Rechercher
                </button>
            </form>
        </div>
    </div>

    {% if searchQuery is not empty %}
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent border-0 py-4 px-4">
                <h3 class="h6 mb-0 text-muted">Résultats pour « {{ searchQuery }} »</h3>
            </div>

            {% if searchUsers is empty %}
                <div class="card-body text-center py-5 text-muted">
                    Aucun utilisateur trouvé pour cette recherche.
                </div>
            {% else %}
                {% include 'groups/_user_invite_table.html.twig' with { users: searchUsers, group: group, userStatusRules: userStatusRules, searchQuery: searchQuery } %}
            {% endif %}
        </div>
    {% endif %}

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent border-0 py-4 px-4">
            <h3 class="h6 mb-1 fw-bold">Utilisateurs du site</h3>
            <p class="text-muted small mb-0">
                Membres éligibles hors de ton groupe
                {% if browseTotal > browseUsers|length %}
                    ({{ browseUsers|length }} affichés sur {{ browseTotal }})
                {% else %}
                    ({{ browseTotal }})
                {% endif %}
            </p>
        </div>

        {% if browseUsers is empty %}
            <div class="card-body text-center py-5 text-muted">
                Aucun utilisateur disponible à inviter pour le moment.
            </div>
        {% else %}
            {% include 'groups/_user_invite_table.html.twig' with { users: browseUsers, group: group, userStatusRules: userStatusRules, searchQuery: '' } %}
        {% endif %}
    </div>

    <div class="mt-4">
        <a href="{{ path('app_groups_show', { id: group.id }) }}" class="btn btn-light">
            <i class="bi bi-arrow-left me-1"></i> Retour au groupe
        </a>
    </div>
</div>
{% endblock %}
