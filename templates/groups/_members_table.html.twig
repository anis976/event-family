<div class="card border-0 shadow-sm ef-GroupShow__card-member">
    {% set hide_moderation = hide_moderation|default(false) %}
    <div class="card-header bg-transparent border-0 py-4 px-4 d-flex justify-content-between align-items-center">
        <h3 class="mb-0 h5">{{ 'ui.groups.members.title'|trans }} <span class="badge bg-secondary ms-2">{{ membersTotal }}</span></h3>
    </div>

    <div class="table-responsive px-2">
        <table class="table align-middle table-hover mb-0 ef-GroupShow__card-table">
            <thead class="d-none d-md-table-header-group">
                <tr>
                    <th class="ps-4 py-3 border-0">{{ 'ui.groups.members.column_member'|trans }}</th>
                    <th class="py-3 border-0">{{ 'ui.groups.members.column_role'|trans }}</th>
                    <th class="py-3 border-0 text-end pe-4">{{ 'ui.groups.members.column_actions'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for member in groupMembers %}
                    {% set is_banned = isMember and bannedUserIds[member.user.id] is defined %}
                    {% set is_self = member.user.id == app.user.id %}
                    {% set is_target_owner = member.role.value == 'OWNER' %}
                    {% set can_staff_ban = not hide_moderation and isStaff and not is_self and not is_target_owner and (isOwner or member.role.value == 'MEMBER') %}
                    <tr class="ef-member-row{% if is_banned %} opacity-50 bg-light{% endif %}">
                        <td class="ps-4 py-3">
                            <div class="d-flex align-items-center">
                                <div class="ef-avatar-circle me-3">
                                    {{ member.user.firstName|first|upper }}
                                </div>
                                <div>
                                    <div class="ef-GroupShow__card-table-name">{{ member.user.firstName|capitalize }} {{ member.user.lastName|upper }}</div>
                                    <div class="ef-GroupShow__card-table-pseudo">@{{ member.user.pseudo }}</div>
                                </div>
                            </div>
                        </td>

                        <td class="ef-GroupShow__card-table-badge py-3">
                            {% if is_banned %}
                                <span class="badge ef-badge-role-banni"><i class="bi bi-slash-circle me-1"></i>{{ 'ui.groups.members.role_banned'|trans }}</span>
                            {% elseif is_target_owner %}
                                <span class="badge ef-badge-role-chef"><i class="bi bi-star-fill me-1"></i>{{ 'ui.groups.members.role_owner'|trans }}</span>
                            {% elseif member.role.value == 'MODERATOR' %}
                                <span class="badge ef-badge-role-modo"><i class="bi bi-shield-check me-1"></i>{{ 'ui.groups.members.role_moderator'|trans }}</span>
                            {% else %}
                                <span class="badge ef-badge-role-member">{{ 'ui.groups.members.role_member'|trans }}</span>
                            {% endif %}
                        </td>

                        <td class="text-end pe-4 py-3">
                            {% if not is_banned %}
                                <div class="dropdown d-inline-block">
                                    <button class="ef-GroupShow__btn-three-dots" type="button" data-bs-toggle="dropdown" aria-label="{{ 'ui.groups.members.actions_aria'|trans({'%name%': member.user.displayName}) }}">
                                        <i class="bi bi-three-dots" aria-hidden="true"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end ef-dropdown-menu">
                                        <li>
                                            <a class="dropdown-item" href="{{ path('app_profile_show', { id: member.user.id }) }}">
                                                <i class="bi bi-person me-2"></i>{{ 'ui.groups.members.view_profile'|trans }}
                                            </a>
                                        </li>

                                        {% if not hide_moderation and isOwner and not is_self and not is_target_owner %}
                                            <li>
                                                <button
                                                    type="button"
                                                    class="dropdown-item"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#transfer-owner-modal-{{ member.id }}"
                                                >
                                                    <i class="bi bi-star me-2"></i>{{ 'ui.groups.members.transfer_ownership'|trans }}
                                                </button>
                                            </li>
                                            <li>
                                                <form action="{{ path('app_groups_toggle_modo', { memberId: member.id }) }}" method="POST" data-turbo="false">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle-modo' ~ member.id) }}">
                                                    <button type="submit" class="dropdown-item">
                                                        <i class="bi bi-shield-check me-2"></i>
                                                        {{ member.role.value == 'MODERATOR' ? 'ui.groups.members.remove_moderator'|trans : 'ui.groups.members.make_moderator'|trans }}
                                                    </button>
                                                </form>
                                            </li>
                                        {% endif %}

                                        {% if can_staff_ban %}
                                            <li>
                                                <button
                                                    type="button"
                                                    class="dropdown-item text-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#ban-modal-{{ member.id }}"
                                                >
                                                    <i class="bi bi-slash-circle me-2"></i>{{ 'ui.groups.members.ban'|trans }}
                                                </button>
                                            </li>
                                        {% endif %}

                                        {% if not hide_moderation and isOwner and not is_self and not is_target_owner %}
                                            <li>
                                                <form action="{{ path('app_groups_kick_member', { memberId: member.id }) }}" method="POST" data-turbo="false">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('kick' ~ member.id) }}">
                                                    <button type="submit" class="dropdown-item text-danger">
                                                        <i class="bi bi-person-x me-2"></i>{{ 'ui.groups.members.kick'|trans }}
                                                    </button>
                                                </form>
                                            </li>
                                        {% endif %}

                                        {% if not is_self %}
                                            <li>
                                                <button
                                                    type="button"
                                                    class="dropdown-item"
                                                    data-ef-toggle-message-row="message-row-{{ member.user.id }}"
                                                >
                                                    <i class="bi bi-chat-dots me-2 text-primary"></i>{{ 'ui.groups.members.send_message'|trans }}
                                                </button>
                                            </li>
                                        {% endif %}
                                    </ul>
                                </div>
                            {% elseif isStaff %}
                                <form action="{{ path('app_groups_unban_member', { memberId: member.id }) }}" method="POST" data-turbo="false" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('unban' ~ member.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-check-circle me-1"></i> {{ 'ui.groups.members.unban'|trans }}
                                    </button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                    {% if not is_banned and not is_self %}
                        <tr id="message-row-{{ member.user.id }}" class="d-none ef-GroupShow__message-row">
                            <td colspan="3" class="p-3">
                                <form action="{{ path('app_messages_send_direct') }}" method="POST" class="card border-0 shadow-sm p-3" data-turbo="false">
                                    <input type="hidden" name="_token" value="{{ csrf_token('send_direct_message') }}">
                                    <input type="hidden" name="recipient_id" value="{{ member.user.id }}">
                                    <input type="hidden" name="redirect_route" value="app_groups_show">
                                    <input type="hidden" name="redirect_id" value="{{ group.id }}">
                                    {% if ef_is_site_staff %}
                                        {% include 'messages/_direct_message_send_mode.html.twig' with {
                                            id_prefix: 'group-msg-' ~ member.user.id,
                                        } only %}
                                    {% endif %}
                                    <div class="d-flex flex-column flex-sm-row gap-2">
                                        <input
                                            type="text"
                                            name="content"
                                            class="form-control ef-input"
                                            placeholder="{{ 'ui.groups.members.message_placeholder'|trans }}"
                                            aria-label="{{ 'ui.groups.members.message_label'|trans({'%name%': member.user.firstName|capitalize}) }}"
                                            required
                                        >
                                        <div class="d-flex gap-2">
                                            <button type="submit" class="btn ef-GroupShow__btn-send">{{ 'ui.common.send'|trans }}</button>
                                            <button type="button" class="btn btn-light" data-ef-close-message-row="message-row-{{ member.user.id }}">{{ 'ui.common.cancel'|trans }}</button>
                                        </div>
                                    </div>
                                </form>
                            </td>
                        </tr>
                    {% endif %}
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% include 'components/_ef_paginate.html.twig' with {
        pagination: membersPagination,
        route_name: 'app_groups_show',
        route_params: { id: group.id },
        wrapper_class: 'd-flex justify-content-center ef-paginate mt-4 mb-2',
        aria_label: 'ui.groups.members.pagination_aria'|trans,
    } only %}
</div>

{% for member in groupMembers %}
    {% set is_self = member.user.id == app.user.id %}
    {% set is_target_owner = member.role.value == 'OWNER' %}
    {% set can_staff_ban = not hide_moderation and isStaff and not is_self and not is_target_owner and (isOwner or member.role.value == 'MEMBER') %}
    {% if can_staff_ban %}
        <div class="modal fade ef-GroupShow__ban-modal" id="ban-modal-{{ member.id }}" tabindex="-1" aria-labelledby="ban-modal-label-{{ member.id }}" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <form action="{{ path('app_groups_ban_member', { memberId: member.id }) }}" method="POST" data-turbo="false">
                        <input type="hidden" name="_token" value="{{ csrf_token('ban' ~ member.id) }}">
                        <div class="modal-header border-0">
                            <h5 class="modal-title" id="ban-modal-label-{{ member.id }}">
                                {{ 'ui.groups.members.ban_modal_title'|trans({'%name%': member.user.firstName ~ ' ' ~ member.user.lastName}) }}
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'ui.common.close'|trans }}"></button>
                        </div>
                        <div class="modal-body">
                            <p class="text-muted small mb-3">
                                {{ 'ui.groups.members.ban_modal_hint'|trans }}
                            </p>
                            <label for="ban-reason-{{ member.id }}" class="form-label fw-medium">{{ 'ui.groups.members.ban_reason_label'|trans }} <span class="text-danger">*</span></label>
                            <textarea
                                id="ban-reason-{{ member.id }}"
                                name="reason"
                                class="form-control ef-input ef-GroupShow__ban-textarea"
                                rows="5"
                                maxlength="2000"
                                required
                                placeholder="{{ 'ui.groups.members.ban_reason_placeholder'|trans }}"
                            ></textarea>
                        </div>
                        <div class="modal-footer border-0">
                            <button type="button" class="btn ef-groups-form__btn-cancel px-4" data-bs-dismiss="modal">{{ 'ui.common.cancel'|trans }}</button>
                            <button type="submit" class="btn btn-danger">{{ 'ui.groups.members.ban_confirm'|trans }}</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    {% endif %}
{% endfor %}

{% if isOwner %}
    {% for member in groupMembers %}
        {% set is_self = member.user.id == app.user.id %}
        {% set is_target_owner = member.role.value == 'OWNER' %}
        {% if not is_self and not is_target_owner %}
            <div class="modal fade ef-GroupShow__transfer-modal" id="transfer-owner-modal-{{ member.id }}" tabindex="-1" aria-labelledby="transfer-owner-modal-label-{{ member.id }}" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow">
                        <form action="{{ path('app_groups_transfer_ownership', { memberId: member.id }) }}" method="POST" data-turbo="false">
                            <input type="hidden" name="_token" value="{{ csrf_token('transfer-owner' ~ member.id) }}">
                            <div class="modal-header border-0">
                                <h5 class="modal-title" id="transfer-owner-modal-label-{{ member.id }}">
                                    {{ 'ui.groups.transfer.modal_title'|trans({'%name%': member.user.firstName ~ ' ' ~ member.user.lastName}) }}
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'ui.common.close'|trans }}"></button>
                            </div>
                            <div class="modal-body">
                                <p class="text-muted small mb-3">{{ 'ui.groups.transfer.modal_hint'|trans }}</p>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" name="transfer_ownership[becomeModerator]" value="1" id="transfer-become-modo-{{ member.id }}">
                                    <label class="form-check-label" for="transfer-become-modo-{{ member.id }}">
                                        {{ 'ui.groups.transfer.become_moderator'|trans }}
                                    </label>
                                </div>
                                <label for="transfer-password-{{ member.id }}" class="form-label fw-medium">{{ 'ui.profile.form.label.current_password'|trans }} <span class="text-danger">*</span></label>
                                <input
                                    type="password"
                                    id="transfer-password-{{ member.id }}"
                                    name="transfer_ownership[currentPassword]"
                                    class="form-control ef-input"
                                    autocomplete="current-password"
                                    required
                                    placeholder="{{ 'ui.auth.placeholder.password_current'|trans }}"
                                >
                            </div>
                            <div class="modal-footer border-0">
                                <button type="button" class="btn ef-groups-form__btn-cancel px-4" data-bs-dismiss="modal">{{ 'ui.common.cancel'|trans }}</button>
                                <button type="submit" class="btn btn-danger">{{ 'ui.groups.transfer.confirm'|trans }}</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        {% endif %}
    {% endfor %}
{% endif %}
