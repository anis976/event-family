<div class="col">
    <a href="{{ card_href }}" class="card h-100 ef-groups__card border-0 shadow-sm text-body text-decoration-none{% if is_staff_circle|default(false) %} ef-groups__card--staff-circle{% endif %}" aria-label="{{ 'ui.groups.card_link_aria'|trans({
        '%name%': group.name,
        '%members%': 'ui.groups.member_count'|trans({'%count%': member_count|default(group.groupMembers|length)}),
    }) }}">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start mb-1 gap-2">
                <h2 class="h5 card-title mb-0">{{ group.name }}</h2>
                {% if is_staff_circle|default(false) %}
                    <span class="ef-groups__badge-staff-circle flex-shrink-0" aria-hidden="true">
                        <i class="bi bi-people-fill me-1" aria-hidden="true"></i>{{ 'ui.groups.staff_circle.badge'|trans }}
                    </span>
                {% elseif app.user and group.owner and app.user.id == group.owner.id %}
                    <span class="ef-groups__badge-leader" aria-hidden="true">
                        <i class="bi bi-crown-fill me-1" aria-hidden="true"></i> {{ 'ui.groups.role.leader_badge'|trans }}
                    </span>
                {% endif %}
            </div>

            <p class="mb-2 card-famyliName">{{ group.familyName }}</p>

            <p class="ef-groups__card-description mb-3">
                {% set desc = group.description|default('') %}
                {% if desc %}
                    {{ desc|length > 100 ? desc|slice(0, 100) ~ '…' : desc }}
                {% else %}
                    {{ 'ui.common.no_description'|trans }}
                {% endif %}
            </p>

            <div class="ef-groups__card-footer pt-3 border-top mt-auto">
                <div class="d-flex align-items-center justify-content-between ef-groups__family-info">
                    <span class="small">
                        <i class="bi bi-people me-1" aria-hidden="true"></i>
                        <span aria-hidden="true">{{ 'ui.groups.member_count'|trans({'%count%': member_count|default(group.groupMembers|length)}) }}</span>
                    </span>
                    <span class="small text-muted ef-groups__card-link-hint" aria-hidden="true">
                        {% if is_staff_circle|default(false) and not (is_staff_circle_member|default(false)) %}
                            {{ 'ui.groups.staff_circle.view_only'|trans }}
                        {% else %}
                            {{ 'ui.common.view'|trans }} <i class="bi bi-arrow-right-short" aria-hidden="true"></i>
                        {% endif %}
                    </span>
                </div>
            </div>
        </div>
    </a>
</div>
