<div class="col">
    <a href="{{ card_href }}" class="card h-100 ef-groups__card border-0 shadow-sm text-body text-decoration-none">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start mb-1">
                <h2 class="h5 card-title mb-0">{{ group.name }}</h2>
                {% if app.user and group.owner and app.user.id == group.owner.id %}
                    <span class="ef-groups__badge-leader">
                        <i class="bi bi-crown-fill me-1"></i> Chef
                    </span>
                {% endif %}
            </div>

            <p class="mb-2 card-famyliName">{{ group.familyName }}</p>

            <p class="ef-groups__card-description mb-3">
                {% set desc = group.description|default('Aucune description fournie.') %}
                {{ desc|length > 100 ? desc|slice(0, 100) ~ '…' : desc }}
            </p>

            <div class="ef-groups__card-footer pt-3 border-top mt-auto">
                <div class="d-flex align-items-center justify-content-between ef-groups__family-info">
                    <span class="small">
                        <i class="bi bi-people me-1"></i>
                        {{ group.groupMembers|length }} membre{{ group.groupMembers|length > 1 ? 's' : '' }}
                    </span>
                    <span class="small text-muted ef-groups__card-link-hint">
                        Voir <i class="bi bi-arrow-right-short"></i>
                    </span>
                </div>
            </div>
        </div>
    </a>
</div>
