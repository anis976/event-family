{% extends 'layout/error.html.twig' %}

{% block title %}{{ 'ui.error.not_found.page_title'|trans }}{% endblock %}

{% block body %}
    <main class="ef-error-page__main" role="main" aria-labelledby="ef-error-404-title">
        <div class="ef-error-page__inner">
            <div class="ef-error-page__card text-center">
                <p class="ef-error-page__code" aria-hidden="true">{{ 'ui.error.not_found.code'|trans }}</p>

                <div class="ef-error-page__icon" aria-hidden="true">
                    <i class="bi bi-signpost-split"></i>
                </div>

                <h1 id="ef-error-404-title" class="ef-error-page__title">{{ 'ui.error.not_found.title'|trans }}</h1>
                <p class="ef-error-page__message">{{ 'ui.error.not_found.message'|trans }}</p>
                <p class="ef-error-page__hint">{{ 'ui.error.not_found.hint'|trans }}</p>

                <div class="ef-error-page__actions">
                    <a href="{{ path('app_home') }}" class="ef-error-page__btn ef-error-page__btn--primary">
                        <i class="bi bi-house-door me-2" aria-hidden="true"></i>{{ 'ui.error.not_found.back_home'|trans }}
                    </a>
                    {% if app.user %}
                        <a href="{{ path('app_contact') }}" class="ef-error-page__btn ef-error-page__btn--secondary">
                            <i class="bi bi-envelope me-2" aria-hidden="true"></i>{{ 'ui.error.not_found.contact'|trans }}
                        </a>
                    {% else %}
                        <a href="{{ path('app_about') }}" class="ef-error-page__btn ef-error-page__btn--secondary">
                            <i class="bi bi-info-circle me-2" aria-hidden="true"></i>{{ 'ui.error.not_found.about'|trans }}
                        </a>
                    {% endif %}
                </div>
            </div>

            <p class="ef-error-page__brand">
                <a href="{{ path('app_home') }}" class="ef-error-page__brand-link">
                    <i class="bi bi-calendar-heart me-1" aria-hidden="true"></i>RapproFam
                </a>
            </p>
        </div>
    </main>
{% endblock %}
