{% extends 'base.html.twig' %}

{% block body_class %} ef-home{% if not app.user %} ef-home--guest{% endif %}{% endblock %}

{% block page_title %}{{ 'ui.home.title'|trans }}{% endblock %}

{% block title %}{{ app.user ? 'ui.home.page_title'|trans : 'ui.home.guest_page_title'|trans }}{% endblock %}

{% block meta_description %}
    {% if not app.user %}
        <meta name="description" content="{{ 'ui.home.guest_meta_description'|trans }}">
    {% endif %}
{% endblock %}

{% block meta_og %}
    {% if not app.user %}
        <meta property="og:type" content="website">
        <meta property="og:title" content="{{ 'ui.home.guest_page_title'|trans }}">
        <meta property="og:description" content="{{ 'ui.home.guest_meta_description'|trans }}">
        <meta property="og:locale" content="{{ app.request.locale == 'en' ? 'en_US' : 'fr_FR' }}">
    {% endif %}
{% endblock %}

{% block body %}
    <section class="ef-hero-section">
        <div class="ef-hero-section__overlay" aria-hidden="true"></div>

        <div class="position-relative text-center ef-hero-section__content">
            <h1 class="display-4 fw-bold">
                {{ app.user ? 'ui.home.welcome'|trans : 'ui.home.guest_welcome'|trans }}
            </h1>
            <p class="lead mb-0">
                {{ app.user ? 'ui.home.lead'|trans : 'ui.home.guest_lead'|trans }}
            </p>
        </div>

        <div class="ef-hero-section__wave-container">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320" aria-hidden="true" focusable="false">
                <path
                    fill="currentColor"
                    fill-opacity="1"
                    d="M0,224L48,213.3C96,203,192,181,288,181.3C384,181,480,203,576,224C672,245,768,267,864,250.7C960,235,1056,181,1152,165.3C1248,149,1344,171,1392,181.3L1440,192L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"
                ></path>
            </svg>
        </div>
    </section>

    <div class="ef-main-content-padding">
        <div class="row g-4 text-center mb-5">
            <div class="col-12 col-md-6 col-lg-4">
                {% if app.user %}
                    <a href="{{ path('app_groups') }}" class="card h-100 ef-card ef-card--link border-0 shadow-sm text-center p-4">
                {% else %}
                    <div class="card h-100 ef-card border-0 shadow-sm text-center p-4">
                {% endif %}
                    <div class="ef-icon-box mx-auto mb-3">
                        <i class="bi bi-people fs-3" aria-hidden="true"></i>
                    </div>
                    <h2 class="h5 fw-bold">{{ 'ui.home.feature_groups_title'|trans }}</h2>
                    <p class="text-muted small mb-0">{{ 'ui.home.feature_groups_text'|trans }}</p>
                {% if app.user %}
                    </a>
                {% else %}
                    </div>
                {% endif %}
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                {% if app.user %}
                    <a href="{{ path('app_events') }}" class="card h-100 ef-card ef-card--link border-0 shadow-sm text-center p-4">
                {% else %}
                    <div class="card h-100 ef-card border-0 shadow-sm text-center p-4">
                {% endif %}
                    <div class="ef-icon-box mx-auto mb-3">
                        <i class="bi bi-calendar-event fs-3" aria-hidden="true"></i>
                    </div>
                    <h2 class="h5 fw-bold">{{ 'ui.home.feature_events_title'|trans }}</h2>
                    <p class="text-muted small mb-0">{{ 'ui.home.feature_events_text'|trans }}</p>
                {% if app.user %}
                    </a>
                {% else %}
                    </div>
                {% endif %}
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                {% if app.user %}
                    <a href="{{ path('app_messages') }}" class="card h-100 ef-card ef-card--link border-0 shadow-sm text-center p-4">
                {% else %}
                    <div class="card h-100 ef-card border-0 shadow-sm text-center p-4">
                {% endif %}
                    <div class="ef-icon-box mx-auto mb-3">
                        <i class="bi bi-stars fs-3" aria-hidden="true"></i>
                    </div>
                    <h2 class="h5 fw-bold">{{ 'ui.home.feature_connect_title'|trans }}</h2>
                    <p class="text-muted small mb-0">{{ 'ui.home.feature_connect_text'|trans }}</p>
                {% if app.user %}
                    </a>
                {% else %}
                    </div>
                {% endif %}
            </div>
        </div>

        {% include 'components/_ef_adsense_unit.html.twig' with { slot: ef_google_adsense_slot_home } only %}

        {% if app.user %}
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold h4 mb-0 text-body text-truncate me-2 ef-home__section-title">
                    {{ 'ui.home.upcoming_events'|trans }}
                </h2>
                <a href="{{ path('app_events') }}" class="btn ef-btn-viewAllEvent btn-sm rounded-pill px-3 shadow-sm flex-shrink-0 text-nowrap">
                    {{ 'ui.home.view_all_events'|trans }} <i class="bi bi-chevron-right ms-1" aria-hidden="true"></i>
                </a>
            </div>

            {% if upcomingPublicEvents is empty %}
                {% include 'events/_empty.html.twig' with { message: 'ui.home.no_public_events'|trans } %}
            {% else %}
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-3">
                    {% for event in upcomingPublicEvents %}
                        {% include 'events/_article_card.html.twig' with { event: event, is_past: false, use_modal: false } %}
                    {% endfor %}
                </div>
            {% endif %}
        {% else %}
            <div class="ef-home-guest">
                <section class="ef-home-guest__how" aria-labelledby="ef-home-guest-how-title">
                    <h2 id="ef-home-guest-how-title" class="ef-home-guest__how-title">{{ 'ui.home.guest_how_title'|trans }}</h2>
                    <div class="row g-4 ef-home-guest__steps">
                        <div class="col-12 col-md-4">
                            <article class="ef-home-guest__step">
                                <span class="ef-home-guest__step-num" aria-hidden="true">1</span>
                                <h3 class="ef-home-guest__step-title">{{ 'ui.home.guest_step1_title'|trans }}</h3>
                                <p class="ef-home-guest__step-text">{{ 'ui.home.guest_step1_text'|trans }}</p>
                            </article>
                        </div>
                        <div class="col-12 col-md-4">
                            <article class="ef-home-guest__step">
                                <span class="ef-home-guest__step-num" aria-hidden="true">2</span>
                                <h3 class="ef-home-guest__step-title">{{ 'ui.home.guest_step2_title'|trans }}</h3>
                                <p class="ef-home-guest__step-text">{{ 'ui.home.guest_step2_text'|trans }}</p>
                            </article>
                        </div>
                        <div class="col-12 col-md-4">
                            <article class="ef-home-guest__step">
                                <span class="ef-home-guest__step-num" aria-hidden="true">3</span>
                                <h3 class="ef-home-guest__step-title">{{ 'ui.home.guest_step3_title'|trans }}</h3>
                                <p class="ef-home-guest__step-text">{{ 'ui.home.guest_step3_text'|trans }}</p>
                            </article>
                        </div>
                    </div>
                </section>

                <p class="ef-home-guest__notice" role="note">{{ 'ui.home.guest_private_notice'|trans }}</p>

                <div class="ef-home-guest__cta">
                    <a href="{{ path('app_register') }}" class="ef-home-guest__cta-btn ef-home-guest__cta-btn--primary">
                        {{ 'ui.home.guest_cta_register'|trans }}
                    </a>
                    <a href="{{ path('app_login') }}" class="ef-home-guest__cta-btn ef-home-guest__cta-btn--secondary">
                        {{ 'ui.home.guest_cta_login'|trans }}
                    </a>
                </div>

                <p class="ef-home-guest__about">
                    <a href="{{ path('app_about') }}" class="ef-home-guest__about-link">
                        {{ 'ui.home.guest_about_cta'|trans }}
                        <i class="bi bi-arrow-right" aria-hidden="true"></i>
                    </a>
                </p>
            </div>
        {% endif %}
    </div>
{% endblock %}
