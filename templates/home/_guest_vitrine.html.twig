{# Vitrine publique — contenu riche pour SEO / AdSense #}
<div class="ef-home-guest">
    <section class="ef-home-guest__features" aria-labelledby="ef-home-guest-features-title">
        <h2 id="ef-home-guest-features-title" class="ef-home-guest__section-title">{{ 'ui.home.guest_features_title'|trans }}</h2>
        <p class="ef-home-guest__section-lead">{{ 'ui.home.guest_features_lead'|trans }}</p>

        <div class="ef-home-guest__feature-list">
            <article class="ef-home-guest__feature-row">
                <div class="ef-home-guest__feature-copy">
                    <div class="ef-icon-box mx-auto mb-3" aria-hidden="true">
                        <i class="bi bi-people-fill fs-3"></i>
                    </div>
                    <h3 class="ef-home-guest__feature-heading">{{ 'ui.home.guest_feature_groups_title'|trans }}</h3>
                    <p class="ef-home-guest__feature-text">{{ 'ui.home.guest_feature_groups_text'|trans }}</p>
                </div>
                <div class="ef-home-guest__mock" role="img" aria-label="{{ 'ui.home.guest_mock_groups_aria'|trans }}">
                    <div class="ef-home-guest__mock-bar"><span></span><span></span><span></span></div>
                    <div class="ef-home-guest__mock-body">
                        <div class="ef-home-guest__mock-card">
                            <span class="ef-icon-box ef-icon-box--sm"><i class="bi bi-people" aria-hidden="true"></i></span>
                            <div>
                                <strong>{{ 'ui.home.guest_mock_groups_name'|trans }}</strong>
                                <small>{{ 'ui.home.guest_mock_groups_meta'|trans }}</small>
                            </div>
                        </div>
                        <div class="ef-home-guest__mock-card ef-home-guest__mock-card--muted">
                            <span class="ef-icon-box ef-icon-box--sm"><i class="bi bi-people" aria-hidden="true"></i></span>
                            <div>
                                <strong>{{ 'ui.home.guest_mock_groups_name2'|trans }}</strong>
                                <small>{{ 'ui.home.guest_mock_groups_meta2'|trans }}</small>
                            </div>
                        </div>
                    </div>
                </div>
            </article>

            <article class="ef-home-guest__feature-row ef-home-guest__feature-row--reverse">
                <div class="ef-home-guest__feature-copy">
                    <div class="ef-icon-box mx-auto mb-3" aria-hidden="true">
                        <i class="bi bi-calendar-event fs-3"></i>
                    </div>
                    <h3 class="ef-home-guest__feature-heading">{{ 'ui.home.guest_feature_events_title'|trans }}</h3>
                    <p class="ef-home-guest__feature-text">{{ 'ui.home.guest_feature_events_text'|trans }}</p>
                </div>
                <div class="ef-home-guest__mock" role="img" aria-label="{{ 'ui.home.guest_mock_events_aria'|trans }}">
                    <div class="ef-home-guest__mock-bar"><span></span><span></span><span></span></div>
                    <div class="ef-home-guest__mock-body">
                        <div class="ef-home-guest__mock-event">
                            <div class="ef-home-guest__mock-event-date">{{ 'ui.home.guest_mock_event_date'|trans }}</div>
                            <div>
                                <strong>{{ 'ui.home.guest_mock_event_title'|trans }}</strong>
                                <small>{{ 'ui.home.guest_mock_event_place'|trans }}</small>
                            </div>
                        </div>
                        <div class="ef-home-guest__mock-event">
                            <div class="ef-home-guest__mock-event-date ef-home-guest__mock-event-date--alt">{{ 'ui.home.guest_mock_event_date2'|trans }}</div>
                            <div>
                                <strong>{{ 'ui.home.guest_mock_event_title2'|trans }}</strong>
                                <small>{{ 'ui.home.guest_mock_event_place2'|trans }}</small>
                            </div>
                        </div>
                    </div>
                </div>
            </article>

            <article class="ef-home-guest__feature-row">
                <div class="ef-home-guest__feature-copy">
                    <div class="ef-icon-box mx-auto mb-3" aria-hidden="true">
                        <i class="bi bi-envelope-check fs-3"></i>
                    </div>
                    <h3 class="ef-home-guest__feature-heading">{{ 'ui.home.guest_feature_invites_title'|trans }}</h3>
                    <p class="ef-home-guest__feature-text">{{ 'ui.home.guest_feature_invites_text'|trans }}</p>
                </div>
                <div class="ef-home-guest__mock" role="img" aria-label="{{ 'ui.home.guest_mock_invites_aria'|trans }}">
                    <div class="ef-home-guest__mock-bar"><span></span><span></span><span></span></div>
                    <div class="ef-home-guest__mock-body">
                        <div class="ef-home-guest__mock-invite">
                            <span class="ef-icon-box ef-icon-box--sm"><i class="bi bi-envelope-check" aria-hidden="true"></i></span>
                            <div>
                                <strong>{{ 'ui.home.guest_mock_invite_title'|trans }}</strong>
                                <small>{{ 'ui.home.guest_mock_invite_text'|trans }}</small>
                            </div>
                            <span class="ef-home-guest__mock-pill">{{ 'ui.home.guest_mock_invite_badge'|trans }}</span>
                        </div>
                    </div>
                </div>
            </article>

            <article class="ef-home-guest__feature-row ef-home-guest__feature-row--reverse">
                <div class="ef-home-guest__feature-copy">
                    <div class="ef-icon-box mx-auto mb-3" aria-hidden="true">
                        <i class="bi bi-chat-left-text fs-3"></i>
                    </div>
                    <h3 class="ef-home-guest__feature-heading">{{ 'ui.home.guest_feature_messages_title'|trans }}</h3>
                    <p class="ef-home-guest__feature-text">{{ 'ui.home.guest_feature_messages_text'|trans }}</p>
                </div>
                <div class="ef-home-guest__mock" role="img" aria-label="{{ 'ui.home.guest_mock_messages_aria'|trans }}">
                    <div class="ef-home-guest__mock-bar"><span></span><span></span><span></span></div>
                    <div class="ef-home-guest__mock-body">
                        <div class="ef-home-guest__mock-message">
                            <span class="ef-home-guest__mock-avatar" aria-hidden="true"></span>
                            <div class="ef-home-guest__mock-bubble">
                                <strong>{{ 'ui.home.guest_mock_message_author'|trans }}</strong>
                                <p>{{ 'ui.home.guest_mock_message_text'|trans }}</p>
                            </div>
                        </div>
                        <div class="ef-home-guest__mock-message ef-home-guest__mock-message--reply">
                            <span class="ef-home-guest__mock-avatar ef-home-guest__mock-avatar--alt" aria-hidden="true"></span>
                            <div class="ef-home-guest__mock-bubble">
                                <strong>{{ 'ui.home.guest_mock_message_author2'|trans }}</strong>
                                <p>{{ 'ui.home.guest_mock_message_text2'|trans }}</p>
                            </div>
                        </div>
                    </div>
                </div>
            </article>
        </div>

        <p class="ef-home-guest__faq-teaser text-center">
            <a href="{{ path('app_features') }}" class="ef-home-guest__faq-teaser-link mt-2">
                {{ 'ui.home.guest_features_link'|trans }}
                <i class="bi bi-arrow-right" aria-hidden="true"></i>
            </a>
        </p>
    </section>

    <section class="ef-home-guest__use-cases" aria-labelledby="ef-home-guest-use-cases-title">
        <h2 id="ef-home-guest-use-cases-title" class="ef-home-guest__section-title">{{ 'ui.home.guest_use_cases_title'|trans }}</h2>
        <p class="ef-home-guest__section-lead">{{ 'ui.home.guest_use_cases_lead'|trans }}</p>
        <div class="row g-3 ef-home-guest__use-cases-grid">
            <div class="col-12 col-md-6">
                <article class="ef-home-guest__use-case">
                    <div class="ef-icon-box mx-auto mb-3" aria-hidden="true">
                        <i class="bi bi-balloon-heart fs-3"></i>
                    </div>
                    <h3 class="ef-home-guest__use-case-title">{{ 'ui.home.guest_use_case_birthday_title'|trans }}</h3>
                    <p class="ef-home-guest__use-case-text">{{ 'ui.home.guest_use_case_birthday_text'|trans }}</p>
                </article>
            </div>
            <div class="col-12 col-md-6">
                <article class="ef-home-guest__use-case">
                    <div class="ef-icon-box mx-auto mb-3" aria-hidden="true">
                        <i class="bi bi-gift fs-3"></i>
                    </div>
                    <h3 class="ef-home-guest__use-case-title">{{ 'ui.home.guest_use_case_christmas_title'|trans }}</h3>
                    <p class="ef-home-guest__use-case-text">{{ 'ui.home.guest_use_case_christmas_text'|trans }}</p>
                </article>
            </div>
            <div class="col-12 col-md-6">
                <article class="ef-home-guest__use-case">
                    <div class="ef-icon-box mx-auto mb-3" aria-hidden="true">
                        <i class="bi bi-house-heart fs-3"></i>
                    </div>
                    <h3 class="ef-home-guest__use-case-title">{{ 'ui.home.guest_use_case_reunion_title'|trans }}</h3>
                    <p class="ef-home-guest__use-case-text">{{ 'ui.home.guest_use_case_reunion_text'|trans }}</p>
                </article>
            </div>
            <div class="col-12 col-md-6">
                <article class="ef-home-guest__use-case">
                    <div class="ef-icon-box mx-auto mb-3" aria-hidden="true">
                        <i class="bi bi-geo-alt fs-3"></i>
                    </div>
                    <h3 class="ef-home-guest__use-case-title">{{ 'ui.home.guest_use_case_distance_title'|trans }}</h3>
                    <p class="ef-home-guest__use-case-text">{{ 'ui.home.guest_use_case_distance_text'|trans }}</p>
                </article>
            </div>
        </div>
    </section>

    <p class="ef-home-guest__faq-teaser text-center">
        <span class="ef-home-guest__faq-teaser-label">{{ 'ui.home.guest_guide_teaser'|trans }}</span>
        <a href="{{ path('app_family_events_guide') }}" class="ef-home-guest__faq-teaser-link">
            {{ 'ui.home.guest_guide_link'|trans }}
            <i class="bi bi-arrow-right" aria-hidden="true"></i>
        </a>
    </p>

    <p class="ef-home-guest__faq-teaser text-center">
        <span class="ef-home-guest__faq-teaser-label">{{ 'ui.home.guest_faq_teaser'|trans }}</span>
        <a href="{{ path('app_faq') }}" class="ef-home-guest__faq-teaser-link">
            {{ 'ui.home.guest_faq_link'|trans }}
            <i class="bi bi-arrow-right" aria-hidden="true"></i>
        </a>
    </p>

    <section class="ef-home-guest__how" aria-labelledby="ef-home-guest-how-title">
        <h2 id="ef-home-guest-how-title" class="ef-home-guest__how-title">{{ 'ui.home.guest_how_title'|trans }}</h2>
        <div class="row g-4 ef-home-guest__steps">
            <div class="col-12 col-md-4">
                <article class="ef-home-guest__step">
                    <span class="ef-home-guest__step-num" aria-hidden="true">1</span>
                    <h3 class="ef-home-guest__step-title">{{ 'ui.home.guest_step1_title'|trans }}</h3>
                    <p class="ef-home-guest__step-text">{{ 'ui.home.guest_step1_text'|trans }}</p>
                </article>
            </div>
            <div class="col-12 col-md-4">
                <article class="ef-home-guest__step">
                    <span class="ef-home-guest__step-num" aria-hidden="true">2</span>
                    <h3 class="ef-home-guest__step-title">{{ 'ui.home.guest_step2_title'|trans }}</h3>
                    <p class="ef-home-guest__step-text">{{ 'ui.home.guest_step2_text'|trans }}</p>
                </article>
            </div>
            <div class="col-12 col-md-4">
                <article class="ef-home-guest__step">
                    <span class="ef-home-guest__step-num" aria-hidden="true">3</span>
                    <h3 class="ef-home-guest__step-title">{{ 'ui.home.guest_step3_title'|trans }}</h3>
                    <p class="ef-home-guest__step-text">{{ 'ui.home.guest_step3_text'|trans }}</p>
                </article>
            </div>
        </div>
    </section>

    {% if not app.user %}
    <p class="ef-home-guest__notice" role="note">{{ 'ui.home.guest_private_notice'|trans }}</p>
    {% else %}
    <p class="ef-home-guest__notice" role="note">{{ 'ui.home.vitrine_private_notice'|trans }}</p>
    {% endif %}

    {% if not app.user %}
    <div class="ef-home-guest__cta">
        <a href="{{ path('app_register') }}" class="ef-home-guest__cta-btn ef-home-guest__cta-btn--primary">
            {{ 'ui.home.guest_cta_register'|trans }}
        </a>
        <a href="{{ path('app_login') }}" class="ef-home-guest__cta-btn ef-home-guest__cta-btn--secondary">
            {{ 'ui.home.guest_cta_login'|trans }}
        </a>
    </div>
    {% endif %}

    <p class="ef-home-guest__about">
        <a href="{{ path('app_about') }}" class="ef-home-guest__about-link">
            {{ 'ui.home.guest_about_cta'|trans }}
            <i class="bi bi-arrow-right" aria-hidden="true"></i>
        </a>
    </p>
</div>
