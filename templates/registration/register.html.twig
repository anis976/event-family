{% extends 'layout/auth.html.twig' %}

{% block title %}{{ 'ui.auth.register.page_title'|trans }}{% endblock %}

{% block body_class %} ef-signUp{% endblock %}

{% block auth_flash %}{% endblock %}

{% block body %}
    <div class="container-fluid ef-main-wrapper">
        <div class="container">
            <div class="row align-items-center justify-content-center g-4">
                <div class="col-lg-6 d-none d-lg-block text-center">
                    <img
                        src="{{ asset('images/auth/register.webp') }}"
                        class="img-fluid ef-auth__illustration"
                        alt=""
                        role="presentation"
                        width="500"
                        height="450"
                    >
                </div>

                <div class="col-12 col-md-7 col-lg-5 col-xl-5 offset-xl-1 ef-signUp__column">
                    <div class="ef-signUp__alerts">
                        {% include 'components/_ef_flash_messages.html.twig' %}
                    </div>

                    {{ form_start(registrationForm, {
                        attr: {
                            class: 'card shadow-lg p-4 p-sm-5 ef-auth__form-card',
                            novalidate: 'novalidate',
                            'data-turbo': 'false',
                        }
                    }) }}

                    <h1 class="text-center fw-bold mb-3 mt-0 h2">{{ 'ui.auth.register.title'|trans }}</h1>

                    {% include 'components/_ef_form_validation_summary.html.twig' with { form: registrationForm } only %}
                    {{ form_errors(registrationForm) }}

                    <a
                        href="{{ path('app_connect_google_start', { mode: 'signup' }) }}"
                        class="btn btn-google-custom w-100 mb-3 text-decoration-none d-inline-flex align-items-center justify-content-center"
                        data-turbo="false"
                    >
                        <i class="bi bi-google me-2" aria-hidden="true"></i>
                        <span>{{ 'ui.auth.register.google'|trans }}</span>
                    </a>
                    <p class="small text-muted text-center mb-3">{{ 'ui.auth.register.google_terms_hint'|trans }}</p>

                    <div class="divider d-flex align-items-center mb-3">
                        <p class="text-center fw-bold mx-3 mb-0 text-muted small">{{ 'ui.common.or'|trans }}</p>
                    </div>

                    <div class="mb-2">
                        <label class="form-label fw-semibold small" for="{{ registrationForm.email.vars.id }}">{{ 'ui.auth.field.email'|trans }}</label>
                        {{ form_widget(registrationForm.email, { attr: { class: 'form-control' } }) }}
                        {{ form_errors(registrationForm.email) }}
                    </div>

                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <label class="form-label fw-semibold small" for="{{ registrationForm.firstName.vars.id }}">{{ 'ui.auth.field.first_name'|trans }}</label>
                            {{ form_widget(registrationForm.firstName, { attr: { class: 'form-control' } }) }}
                            {{ form_errors(registrationForm.firstName) }}
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold small" for="{{ registrationForm.lastName.vars.id }}">{{ 'ui.auth.field.last_name'|trans }}</label>
                            {{ form_widget(registrationForm.lastName, { attr: { class: 'form-control' } }) }}
                            {{ form_errors(registrationForm.lastName) }}
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label fw-semibold small" for="{{ registrationForm.pseudo.vars.id }}">{{ 'ui.auth.field.pseudo'|trans }}</label>
                        {{ form_widget(registrationForm.pseudo, { attr: { class: 'form-control' } }) }}
                        {{ form_errors(registrationForm.pseudo) }}
                    </div>

                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <label class="form-label fw-semibold small" for="{{ registrationForm.plainPassword.first.vars.id }}">{{ 'ui.auth.field.password'|trans }}</label>
                            {{ form_widget(registrationForm.plainPassword.first, { attr: { class: 'form-control' } }) }}
                            {{ form_errors(registrationForm.plainPassword.first) }}
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold small" for="{{ registrationForm.plainPassword.second.vars.id }}">{{ 'ui.auth.field.confirm_password'|trans }}</label>
                            {{ form_widget(registrationForm.plainPassword.second, { attr: { class: 'form-control' } }) }}
                            {{ form_errors(registrationForm.plainPassword.second) }}
                        </div>
                    </div>

                    <div class="ef-terms-check mb-3">
                        {{ form_widget(registrationForm.agreeTerms, { attr: { class: 'form-check-input' } }) }}
                        <label class="ef-terms-check__label small mb-0" for="{{ registrationForm.agreeTerms.vars.id }}">
                            {{ 'ui.auth.register.accept_terms_prefix'|trans }}
                            <a href="{{ path('app_cgu') }}" class="ef-link-orange fw-bold text-decoration-none" target="_blank" rel="noopener">{{ 'ui.auth.register.accept_terms_link'|trans }}</a>
                        </label>
                    </div>
                    {{ form_errors(registrationForm.agreeTerms) }}

                    <button type="submit" class="btn btn-submit-custom mb-3">{{ 'ui.auth.register.submit'|trans }}</button>

                    <p class="text-center mb-0 small">
                        {{ 'ui.auth.register.has_account'|trans }}
                        <a href="{{ path('app_login') }}" class="ef-link-orange fw-bold text-decoration-none">{{ 'ui.auth.register.login_link'|trans }}</a>
                    </p>

                    {{ form_end(registrationForm) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
