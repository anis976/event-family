<div class="col">
    <article class="card h-100 border-0 shadow-sm ef-events__article{% if is_past|default(false) %} ef-events__article--past{% endif %}">
        {% if use_modal|default(true) %}
            <button
                type="button"
                class="btn p-0 border-0 bg-transparent w-100 text-start ef-events__article-trigger"
                data-bs-toggle="modal"
                data-bs-target="#modal-event-{{ event.id }}"
                data-turbo="false"
            >
                <img
                    src="{{ event_cover_url(event) }}"
                    class="card-img-top ef-events__article-img"
                    alt=""
                    loading="lazy"
                    decoding="async"
                >
            </button>
        {% else %}
            <a href="{{ path('app_events_show', { id: event.id }) }}" class="d-block text-decoration-none" data-turbo="false">
                <img
                    src="{{ event_cover_url(event) }}"
                    class="card-img-top ef-events__article-img"
                    alt=""
                    loading="lazy"
                    decoding="async"
                >
            </a>
        {% endif %}

        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start mb-3 gap-2">
                <h3 class="card-title fw-bold fs-5 mb-0 text-body">{{ event.title }}</h3>
                <span class="badge rounded-pill px-3 ef-events__kind-badge">{{ event.kind.label }}</span>
            </div>

            <ul class="list-unstyled d-flex flex-column gap-1 mb-0">
                <li class="d-flex align-items-center gap-2 text-secondary small">
                    <i class="bi bi-calendar4" aria-hidden="true"></i>
                    <span>{{ event.startDate|date('d/m/Y H:i') }}{% if event.endDate %} — {{ event.endDate|date('d/m/Y H:i') }}{% endif %}</span>
                </li>
                {% if event.location %}
                    <li class="d-flex align-items-center gap-2 text-secondary small">
                        <i class="bi bi-geo-alt" aria-hidden="true"></i>
                        <span>{{ event.location }}</span>
                    </li>
                {% endif %}
                <li class="d-flex align-items-center gap-2 text-secondary small">
                    <i class="bi bi-people" aria-hidden="true"></i>
                    <span>{{ event.relatedGroup.displayLabel }}</span>
                </li>
                {% if event.author %}
                    <li class="d-flex align-items-center gap-2 text-secondary small">
                        <i class="bi bi-person-check" aria-hidden="true"></i>
                        <span>{{ event.author.displayName }}</span>
                    </li>
                {% endif %}
            </ul>
        </div>
    </article>
</div>
