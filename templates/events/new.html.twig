{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.events.page_title'|trans }} — {{ 'ui.events.create'|trans }}{% endblock %}
{% set meta_description_key = 'ui.events.create_meta_description' %}
{% block page_title %}{{ 'ui.events.create'|trans }}{% endblock %}

{% block body %}
<div class="ef-main-content-padding ef-events ef-events--form-page">
    <nav aria-label="{{ 'ui.events.breadcrumb_aria'|trans }}" class="ef-events__breadcrumb">
        <a href="{{ path('app_events') }}" class="ef-events__breadcrumb-link text-decoration-none">{{ 'ui.events.breadcrumb'|trans }}</a>
        <span class="ef-events__breadcrumb-sep" aria-hidden="true">/</span>
        <span class="ef-events__breadcrumb-current" aria-current="page">{{ 'ui.events.breadcrumb_new'|trans }}</span>
    </nav>

    <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-9 col-xl-8">
            <div class="card ef-events-form__card border-0 shadow-sm">
                <div class="card-body p-4 p-md-5">
                    <h1 class="visually-hidden">{{ 'ui.events.create'|trans }}</h1>
                    <p class="h4 fw-bold mb-1">{{ 'ui.events.create_form_title'|trans }}</p>
                    <p class="text-muted mb-4">{{ 'ui.events.create_form_hint'|trans }}</p>

                    {{ form_start(eventForm, { attr: { class: 'ef-events-form', novalidate: 'novalidate' } }) }}
                        {% include 'events/_form_fields.html.twig' with { eventForm: eventForm } %}

                        <div class="d-flex flex-column flex-sm-row gap-2 pt-3">
                            <button type="submit" class="btn btn-save-profile flex-grow-1 py-2 fw-bold shadow-sm">
                                <i class="bi bi-check-all fs-5 me-2" aria-hidden="true"></i>
                                {{ 'ui.events.publish'|trans }}
                            </button>
                            <a href="{{ path('app_events') }}" class="btn ef-events-form__btn-cancel px-4 py-2">{{ 'ui.common.cancel'|trans }}</a>
                        </div>
                    {{ form_end(eventForm) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
