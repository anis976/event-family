{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.events.page_title'|trans }}{% endblock %}
{% set meta_description_key = 'ui.events.meta_description' %}
{% block page_title %}{{ 'ui.events.title'|trans }}{% endblock %}

{% block body %}
{% set events_route_params = { vue: current_filter.value } %}
{% if search_query %}
    {% set events_route_params = events_route_params|merge({ q: search_query }) %}
{% endif %}

<div class="ef-main-content-padding ef-events">
    <h1 class="visually-hidden">{{ 'ui.events.title'|trans }}</h1>

    <div class="d-flex flex-row align-items-center justify-content-between mb-4 ef-events__title">
        <h2 class="m-0">{{ 'ui.events.title'|trans }}</h2>
        {% if can_create %}
            <a href="{{ path('app_events_new') }}" class="btn shadow-sm" data-turbo="false">
                <i class="bi bi-plus-lg me-2" aria-hidden="true"></i> {{ 'ui.events.create'|trans }}
            </a>
        {% endif %}
    </div>

    {% if not can_create %}
        <div class="alert alert-warning border-0 shadow-sm mb-4 ef-events__member-notice" role="status">
            <i class="bi bi-exclamation-circle me-2" aria-hidden="true"></i>
            {{ 'ui.events.member_notice'|trans }}
            <a href="{{ path('app_groups') }}" class="alert-link ms-1">{{ 'ui.events.view_groups'|trans }}</a>
        </div>
    {% endif %}

    {% if search_query %}
        <div class="alert alert-info border-0 shadow-sm mb-4 py-2 d-flex flex-wrap align-items-center justify-content-between gap-2" role="status">
            <span class="small mb-0">
                <i class="bi bi-search me-1" aria-hidden="true"></i>
                {{ 'ui.events.search_results'|trans({
                    '%query%': search_query,
                    '%category%': current_filter.label|trans|lower,
                }) }}
            </span>
            <a href="{{ path('app_events', { vue: current_filter.value }) }}" class="alert-link small text-nowrap">{{ 'ui.events.clear_search'|trans }}</a>
        </div>
    {% endif %}

    <nav class="nav mb-4 ef-events__nav" aria-label="{{ 'ui.events.filters_aria'|trans }}">
        {% for filter in event_filters %}
            <a
                href="{{ path('app_events', events_route_params|merge({ page: 1, vue: filter.value })) }}"
                class="btn{% if current_filter.value == filter.value %} active{% endif %}"
                {% if current_filter.value == filter.value %}aria-current="page"{% endif %}
            >
                {{ filter.label|trans }}
            </a>
        {% endfor %}
    </nav>

    {% include 'components/_ef_adsense_unit.html.twig' with { slot: ef_google_adsense_slot_events } only %}

    {% if events is empty %}
        {% include 'events/_empty.html.twig' with {
            message: search_query
                ? 'ui.events.search_empty'|trans({'%query%': search_query})
                : current_filter.emptyMessage()|trans,
        } %}
    {% else %}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-4">
            {% for event in events %}
                {% include 'events/_article_card.html.twig' with {
                    event: event,
                    is_past: current_filter.value == 'past',
                } %}
            {% endfor %}
        </div>

        {% include 'components/_ef_paginate.html.twig' with {
            pagination: pagination,
            route_name: 'app_events',
            route_params: events_route_params,
            wrapper_class: 'd-flex justify-content-center ef-paginate ef-events__paginate mt-4',
        } %}
    {% endif %}

    {% for event in events %}
        {% include 'events/_modal.html.twig' with {
            event: event,
            current_filter: current_filter,
            is_past: current_filter.value == 'past',
        } %}
    {% endfor %}
</div>
{% endblock %}
