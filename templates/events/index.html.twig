{% extends 'base.html.twig' %}

{% block title %}EventFamily — Événements{% endblock %}
{% block page_title %}Événements{% endblock %}

{% block body %}
<div class="ef-main-content-padding ef-events">
    <div class="d-flex flex-row align-items-center justify-content-between mb-4 ef-events__title">
        <h2 class="m-0">Événements</h2>
        {% if can_create %}
            <a href="{{ path('app_events_new') }}" class="btn shadow-sm" data-turbo="false">
                <i class="bi bi-plus-lg me-2"></i> Créer un événement
            </a>
        {% endif %}
    </div>

    {% if not can_create %}
        <div class="alert alert-warning border-0 shadow-sm mb-4 ef-events__member-notice" role="status">
            <i class="bi bi-exclamation-circle me-2" aria-hidden="true"></i>
            {% if is_regular_member_only %}
                <strong>Publication réservée au chef et au modérateur.</strong>
                Pour proposer un événement, contacte le <strong>chef</strong> ou le <strong>modérateur</strong> de ton groupe
                (<a href="{{ path('app_messages') }}" class="alert-link">Messages privés</a>
                ou depuis la <a href="{{ path('app_groups') }}" class="alert-link">fiche groupe</a>).
            {% else %}
                Pour publier un événement, rejoins un groupe puis contacte son <strong>chef</strong> ou son <strong>modérateur</strong>.
                <a href="{{ path('app_groups') }}" class="alert-link ms-1">Voir les groupes</a>
            {% endif %}
        </div>
    {% endif %}

    <nav class="nav mb-4 ef-events__nav" aria-label="Catégories d'événements">
        {% for filter in [
            { value: 'upcoming', label: 'À venir' },
            { value: 'ongoing', label: 'En cours' },
            { value: 'past', label: 'Passés' },
        ] %}
            <a
                href="{{ path('app_events', { vue: filter.value, page: 1 }) }}"
                class="btn{% if current_filter.value == filter.value %} active{% endif %}"
                {% if current_filter.value == filter.value %}aria-current="page"{% endif %}
            >
                {{ filter.label }}
            </a>
        {% endfor %}
    </nav>

    {% if events is empty %}
        {% include 'events/_empty.html.twig' with { message: current_filter.emptyMessage() } %}
    {% else %}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-4">
            {% for event in events %}
                {% include 'events/_article_card.html.twig' with {
                    event: event,
                    is_past: current_filter.value == 'past',
                } %}
            {% endfor %}
        </div>

        {% include 'components/_ef_paginate.html.twig' with {
            pagination: pagination,
            route_name: 'app_events',
            route_params: { vue: current_filter.value },
            wrapper_class: 'ef-events__paginate mt-4',
        } %}
    {% endif %}

    {% for event in events %}
        {% include 'events/_modal.html.twig' with {
            event: event,
            current_filter: current_filter,
            is_past: current_filter.value == 'past',
        } %}
    {% endfor %}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="module" src="{{ asset('js/ef-events.js') }}"></script>
    <script type="module" src="{{ asset('js/ef-groups.js') }}"></script>
{% endblock %}
