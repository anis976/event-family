{% if pagination.total_pages > 1 %}
<nav class="{{ wrapper_class|default('mt-4 d-flex justify-content-center') }}" aria-label="Pagination">
    <ul class="pagination mb-0">
        <li class="page-item{{ pagination.page <= 1 ? ' disabled' : '' }}">
            <a class="page-link" href="{{ pagination.page <= 1 ? '#' : path(route_name, route_params|merge({ page: pagination.page - 1 })) }}" aria-label="Page précédente">
                <i class="bi bi-chevron-left"></i>
            </a>
        </li>

        {% for p in 1..pagination.total_pages %}
            <li class="page-item{{ p == pagination.page ? ' active' : '' }}">
                <a class="page-link" href="{{ path(route_name, route_params|merge({ page: p })) }}">{{ p }}</a>
            </li>
        {% endfor %}

        <li class="page-item{{ pagination.page >= pagination.total_pages ? ' disabled' : '' }}">
            <a class="page-link" href="{{ pagination.page >= pagination.total_pages ? '#' : path(route_name, route_params|merge({ page: pagination.page + 1 })) }}" aria-label="Page suivante">
                <i class="bi bi-chevron-right"></i>
            </a>
        </li>
    </ul>
</nav>
{% endif %}
