<div class="modal fade ef-session-idle-modal" id="ef-session-idle-modal" tabindex="-1" aria-labelledby="ef-session-idle-title" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="ef-session-idle-title">
                    <i class="bi bi-clock-history me-2 text-warning" aria-hidden="true"></i>
                    {{ 'ui.session.idle.title'|trans }}
                </h5>
            </div>
            <div class="modal-body pt-3">
                <p class="mb-2">{{ 'ui.session.idle.message'|trans }}</p>
                <p class="mb-0">
                    {{ 'ui.session.idle.countdown_prefix'|trans }}
                    <strong id="ef-session-idle-countdown" class="ef-session-idle-modal__countdown">60</strong>
                    {{ 'ui.session.idle.countdown_suffix'|trans }}
                </p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn ef-groups-form__btn-cancel" id="ef-session-idle-logout" data-ef-session-logout>
                    {{ 'ui.session.idle.logout'|trans }}
                </button>
                <button type="button" class="btn btn-save-profile" id="ef-session-idle-stay">
                    {{ 'ui.session.idle.stay'|trans }}
                </button>
            </div>
        </div>
    </div>
</div>
