{% extends 'emails/_base.html.twig' %}

{% block email_title %}{{ 'email.password_change.title'|trans(locale=ef_email_locale) }}{% endblock %}

{% block email_body %}
    <p>{{ 'email.common.greeting'|trans({'%name%': user.displayName}, locale=ef_email_locale) }}</p>
    <p>{{ 'email.password_change.intro'|trans(locale=ef_email_locale)|raw }}</p>
    <p>{{ 'email.password_change.cta_intro'|trans({
        '%expires%': 'email.common.expires_hours'|trans({'%hours%': expiresHours}, locale=ef_email_locale),
    }, locale=ef_email_locale) }}</p>
    <p style="margin: 2rem 0;">
        <a href="{{ confirmUrl }}"
           style="background: #f37a1f; color: #fff; padding: 12px 24px; text-decoration: none; border-radius: 8px; font-weight: bold;">
            {{ 'email.password_change.cta'|trans(locale=ef_email_locale) }}
        </a>
    </p>
    <p style="font-size: 0.9rem; color: #666;">
        {{ 'email.common.link_fallback'|trans(locale=ef_email_locale) }}<br>
        <a href="{{ confirmUrl }}">{{ confirmUrl }}</a>
    </p>
    <p style="font-size: 0.85rem; color: #999;">{{ 'email.password_change.ignore'|trans(locale=ef_email_locale)|raw }}</p>
{% endblock %}
