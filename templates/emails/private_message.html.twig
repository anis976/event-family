{% extends 'emails/_base.html.twig' %}

{% block email_title %}{{ 'email.private_message.title'|trans(locale=ef_email_locale) }}{% endblock %}

{% block email_body %}
    <p>{{ 'email.common.greeting'|trans({'%name%': user.displayName}, locale=ef_email_locale) }}</p>
    <p>{{ 'email.private_message.intro'|trans({'%name%': sender.displayName}, locale=ef_email_locale)|raw }}</p>
    {% if preview %}
        <blockquote style="margin: 1.25rem 0; padding: 0.75rem 1rem; border-left: 4px solid #f37a1f; background: #fafafa; color: #444;">
            {{ preview|e|nl2br }}
        </blockquote>
    {% endif %}
    <p style="margin: 2rem 0;">
        <a href="{{ messagesUrl }}"
           style="background: #f37a1f; color: #fff; padding: 12px 24px; text-decoration: none; border-radius: 8px; font-weight: bold;">
            {{ 'email.private_message.cta'|trans(locale=ef_email_locale) }}
        </a>
    </p>
    <p style="font-size: 0.85rem; color: #999;">{{ 'email.private_message.opt_out'|trans(locale=ef_email_locale)|raw }}</p>
{% endblock %}
