{% extends 'emails/_base.html.twig' %}

{% block email_title %}{{ 'email.contact.title'|trans(locale=ef_email_locale) }}{% endblock %}

{% block email_body %}
    <p><strong>{{ 'email.contact.heading'|trans(locale=ef_email_locale) }}</strong></p>
    <ul style="list-style: none; padding: 0;">
        <li><strong>{{ 'email.contact.name'|trans(locale=ef_email_locale) }}</strong> {{ user.firstName }} {{ user.lastName }}</li>
        <li><strong>{{ 'email.contact.email'|trans(locale=ef_email_locale) }}</strong> {{ user.email }}</li>
        {% if user.pseudo %}
            <li><strong>{{ 'email.contact.pseudo'|trans(locale=ef_email_locale) }}</strong> @{{ user.pseudo }}</li>
        {% endif %}
        <li><strong>{{ 'email.contact.account_id'|trans(locale=ef_email_locale) }}</strong> {{ user.id }}</li>
        <li><strong>{{ 'email.contact.sent_at'|trans(locale=ef_email_locale) }}</strong> {{ sentAt|ef_datetime(ef_email_locale|default('fr')) }} ({{ 'email.common.paris_time'|trans(locale=ef_email_locale) }})</li>
    </ul>
    <hr>
    <p style="white-space: pre-wrap;">{{ message|e|nl2br }}</p>
    <p style="margin-top: 1.5rem;">
        <a href="mailto:{{ user.email }}?subject={{ ('Re: RapproFam — ' ~ user.firstName ~ ' ' ~ user.lastName)|url_encode }}"
           style="color: #f37a1f; font-weight: bold;">
            {{ 'email.contact.reply_mailto'|trans({'%email%': user.email}, locale=ef_email_locale) }}
        </a>
    </p>
    <p style="font-size: 0.85rem; color: #999;">{{ 'email.contact.reply_hint'|trans(locale=ef_email_locale) }}</p>
{% endblock %}
