{% extends 'emails/_base.html.twig' %}

{% block email_title %}{{ 'email.ban_deleted.title'|trans(locale=ef_email_locale) }}{% endblock %}

{% block email_body %}
    <p>{{ 'email.common.greeting_anonymous'|trans(locale=ef_email_locale) }}</p>
    <p>{{ 'email.ban_deleted.body'|trans({'%count%': banCount}, locale=ef_email_locale)|raw }}</p>

    {% if group %}
        <p>{{ 'email.ban_deleted.last_group'|trans({
            '%name%': group.name,
            '%family%': group.familyName,
        }, locale=ef_email_locale) }}</p>
    {% endif %}

    <p>{{ 'email.ban_deleted.reason_label'|trans(locale=ef_email_locale) }}</p>
    <p style="background: #f8f9fa; padding: 12px; border-left: 4px solid #dc3545;">{{ reason|nl2br }}</p>

    <p style="font-size: 0.85rem; color: #c00;">{{ 'email.ban_deleted.contact'|trans(locale=ef_email_locale) }}</p>
{% endblock %}
