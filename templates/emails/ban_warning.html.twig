{% extends 'emails/_base.html.twig' %}

{% block email_title %}{{ 'email.ban_warning.title'|trans(locale=ef_email_locale) }}{% endblock %}

{% block email_body %}
    <p>{{ 'email.common.greeting'|trans({'%name%': user.firstName}, locale=ef_email_locale) }}</p>

    {% if step == 1 %}
        <p>{{ 'email.ban_warning.step1'|trans({'%max%': maxSteps}, locale=ef_email_locale)|raw }}</p>
    {% elseif step == 2 %}
        <p>{{ 'email.ban_warning.step2'|trans({'%max%': maxSteps}, locale=ef_email_locale)|raw }}</p>
        <p style="color: #c00;">{{ 'email.ban_warning.step2_alert'|trans(locale=ef_email_locale)|raw }}</p>
    {% endif %}

    {% if group %}
        <p>{{ 'email.ban_warning.group'|trans({
            '%name%': group.name,
            '%family%': group.familyName,
        }, locale=ef_email_locale) }}</p>
    {% endif %}

    <p>{{ 'email.ban_warning.reason_label'|trans(locale=ef_email_locale) }}</p>
    <p style="background: #f8f9fa; padding: 12px; border-left: 4px solid #f37a1f;">{{ reason|nl2br }}</p>

    <p style="font-size: 0.9rem; color: #666;">{{ 'email.common.also_in_messages'|trans(locale=ef_email_locale) }}</p>
{% endblock %}
