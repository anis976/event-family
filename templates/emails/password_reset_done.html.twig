{% extends 'emails/_base.html.twig' %}

{% block email_title %}{{ 'email.password_reset_done.title'|trans(locale=ef_email_locale) }}{% endblock %}

{% block email_body %}
    <p>{{ 'email.common.greeting'|trans({'%name%': user.displayName}, locale=ef_email_locale) }}</p>
    <p>{{ 'email.password_reset_done.success'|trans({
        '%date%': changedAt|ef_datetime(ef_email_locale|default('fr')),
        '%timezone%': 'email.common.paris_time'|trans(locale=ef_email_locale),
    }, locale=ef_email_locale)|raw }}</p>
    <p>{{ 'email.password_reset_done.no_action'|trans(locale=ef_email_locale) }}</p>
    <p style="font-size: 0.85rem; color: #c00;">{{ 'email.password_reset_done.alert'|trans(locale=ef_email_locale)|raw }}</p>
{% endblock %}
