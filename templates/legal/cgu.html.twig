{% extends 'layout/legal.html.twig' %}

{% block title %}{{ 'ui.legal.cgu_title'|trans }}{% endblock %}

{% set meta_description_key = 'ui.legal.cgu_meta_description' %}

{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="card ef-legal-card border-0 shadow-sm p-4 p-md-5">
                    <a href="{{ path('app_home') }}" class="btn-return">
                        <i class="bi bi-arrow-left me-2" aria-hidden="true"></i>{{ 'ui.legal.back_home'|trans }}
                    </a>

                    <h1 class="fw-bold mb-5">{{ 'ui.legal.cgu_title'|trans }}</h1>

                    <section class="mb-5" id="privacy" aria-labelledby="ef-legal-privacy-title">
                        <h2 id="ef-legal-privacy-title" class="h4 fw-bold mb-3">
                            <i class="bi bi-shield-lock me-2" aria-hidden="true"></i>{{ 'legal.cgu.privacy.title'|trans }}
                        </h2>
                        <p>{{ 'legal.cgu.privacy.intro'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.privacy.controller_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.privacy.controller_body'|trans({
                            '%address%': ef_publisher_address,
                            '%email%': ef_contact_recipient,
                        })|raw }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.privacy.nature_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.privacy.nature_body'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.privacy.collection_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.privacy.collection_body'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.privacy.purposes_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.privacy.purposes_body'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.privacy.legal_basis_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.privacy.legal_basis_body'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.privacy.third_parties_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.privacy.third_parties_body'|trans|raw }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.privacy.cookies_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.privacy.cookies_body'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.privacy.adsense_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.privacy.adsense_body'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.privacy.retention_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.privacy.retention_body'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.privacy.rights_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.privacy.rights_body'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.privacy.cnil_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.privacy.cnil_body'|trans|raw }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.privacy.transfers_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.privacy.transfers_body'|trans }}</p>

                        <p class="mb-0">
                            {{ 'legal.cgu.privacy.contact_body'|trans }}
                            <a href="mailto:{{ ef_contact_recipient }}">{{ ef_contact_recipient }}</a>.
                        </p>
                    </section>

                    <hr class="my-5 opacity-50">

                    <section aria-labelledby="ef-legal-terms-title">
                        <h2 id="ef-legal-terms-title" class="h4 fw-bold mb-3">
                            <i class="bi bi-file-earmark-text me-2" aria-hidden="true"></i>{{ 'legal.cgu.terms.title'|trans }}
                        </h2>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.terms.purpose_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.terms.purpose_body'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.terms.scope_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.terms.scope_body'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.terms.account_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.terms.account_body'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.terms.user_resp_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.terms.user_resp_body'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.terms.moderation_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.terms.moderation_body'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.terms.publisher_resp_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.terms.publisher_resp_body'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.terms.ip_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.terms.ip_body'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.terms.changes_title'|trans }}</h3>
                        <p>{{ 'legal.cgu.terms.changes_body'|trans }}</p>

                        <h3 class="h6 fw-bold mt-4">{{ 'legal.cgu.terms.law_title'|trans }}</h3>
                        <p class="mb-0">{{ 'legal.cgu.terms.law_body'|trans }}</p>
                    </section>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
