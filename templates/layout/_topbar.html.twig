<header class="ef-topbar d-flex justify-content-between align-items-center bg-body navbar navbar-expand-lg shadow-sm">
    <div class="d-flex align-items-center">
        <button
            class="btn border-0 me-2 d-lg-none"
            type="button"
            id="mobile-toggle"
            aria-label="Ouvrir le menu"
        >
            <i class="bi bi-list fs-2" aria-hidden="true"></i>
        </button>
        <h1 class="mb-0 ef-topbar__title h5">{% block page_title %}Home{% endblock %}</h1>
    </div>

    <div class="d-flex align-items-center gap-1">
        <button
            type="button"
            id="btnSearchToggle"
            class="btn px-2 border-0 ef-topbar__search-btn"
            aria-label="Rechercher"
            aria-expanded="false"
            aria-controls="searchBarCollapse"
        >
            <i class="bi bi-search fs-5" aria-hidden="true"></i>
        </button>

        <div class="dropdown">
            <button
                type="button"
                class="btn border-0 px-2 position-relative ef-topbar__notification"
                data-bs-toggle="dropdown"
                aria-expanded="false"
                aria-label="Notifications{% if ef_notification_count > 0 %} ({{ ef_notification_count }} en attente){% endif %}"
            >
                <i class="bi bi-bell fs-5" aria-hidden="true"></i>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger ef-topbar__notification-badge{% if ef_notification_count <= 0 %} d-none{% endif %}" data-ef-badge="notifications">{{ ef_notification_count }}</span>
            </button>

            <ul class="dropdown-menu dropdown-menu-end ef-dropdown-menu ef-topbar__notification-menu">
                <li><h6 class="dropdown-header">Notifications</h6></li>

                {% if ef_notification_count <= 0 %}
                    <li><span class="dropdown-item-text">Aucune notification en attente</span></li>
                {% endif %}

                <li>
                    <a class="dropdown-item d-flex justify-content-between align-items-center" href="{{ path('app_invitations_index') }}">
                        <span><i class="bi bi-envelope-check me-2"></i> Invitations</span>
                        {% if ef_invitation_count > 0 %}
                            <span class="badge bg-danger rounded-pill" data-ef-badge="invitations">{{ ef_invitation_count }}</span>
                        {% endif %}
                    </a>
                </li>
                <li>
                    <a class="dropdown-item d-flex justify-content-between align-items-center" href="{{ path('app_messages') }}">
                        <span><i class="bi bi-chat-left me-2"></i> Messages</span>
                        {% if ef_message_count > 0 %}
                            <span class="badge bg-danger rounded-pill" data-ef-badge="messages">{{ ef_message_count }}</span>
                        {% endif %}
                    </a>
                </li>

                {% if ef_notification_count > 0 %}
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item small" href="{{ path(ef_notification_target_route) }}">
                            Voir en priorité
                        </a>
                    </li>
                {% endif %}
            </ul>
        </div>

        <div class="dropdown">
            <button
                class="btn dropdown-toggle border-0 px-2 ef-topbar__theme-btn"
                type="button"
                data-bs-toggle="dropdown"
                aria-expanded="false"
                aria-label="Choisir le thème"
            >
                <i class="bi bi-sun-fill" id="theme-icon-main" aria-hidden="true"></i>
            </button>

            <ul class="dropdown-menu dropdown-menu-end ef-dropdown-menu ef-topbar__theme-menu">
                <li>
                    <button type="button" class="dropdown-item" data-ef-theme="light">
                        <i class="bi bi-sun-fill me-2" aria-hidden="true"></i> Clair
                        <i class="bi bi-check2 d-none" aria-hidden="true"></i>
                    </button>
                </li>
                <li>
                    <button type="button" class="dropdown-item" data-ef-theme="dark">
                        <i class="bi bi-moon-stars-fill me-2" aria-hidden="true"></i> Sombre
                        <i class="bi bi-check2 d-none" aria-hidden="true"></i>
                    </button>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <button type="button" class="dropdown-item" data-ef-theme="auto">
                        <i class="bi bi-circle-half me-2" aria-hidden="true"></i> Auto
                        <i class="bi bi-check2 d-none" aria-hidden="true"></i>
                    </button>
                </li>
            </ul>
        </div>
    </div>
</header>
