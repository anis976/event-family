<header class="ef-topbar d-flex justify-content-between align-items-center bg-body navbar navbar-expand-lg shadow-sm">
    <div class="d-flex align-items-center">
        <button
            class="btn border-0 me-2 d-lg-none"
            type="button"
            id="mobile-toggle"
            aria-label="{{ 'ui.topbar.open_menu'|trans }}"
        >
            <i class="bi bi-list fs-2" aria-hidden="true"></i>
        </button>
        <p class="mb-0 ef-topbar__title h5" id="ef-topbar-title">{{ page_title }}</p>
    </div>

    <div class="d-flex align-items-center gap-1">
        {% if app.user %}
        <button
            type="button"
            id="btnSearchToggle"
            class="btn px-2 border-0 ef-topbar__search-btn"
            aria-label="{{ 'ui.topbar.search'|trans }}"
            aria-expanded="false"
            aria-controls="searchBarCollapse"
        >
            <i class="bi bi-search fs-5" aria-hidden="true"></i>
        </button>

        <div class="dropdown">
            <button
                type="button"
                id="ef-notification-bell-btn"
                class="btn border-0 px-2 position-relative ef-topbar__notification"
                data-bs-toggle="dropdown"
                aria-expanded="false"
                aria-label="{{ 'ui.topbar.notifications'|trans }}"
            >
                <i class="bi bi-bell fs-5" aria-hidden="true"></i>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger ef-topbar__notification-badge d-none" data-ef-badge="notifications">0</span>
            </button>

            <ul class="dropdown-menu dropdown-menu-end ef-dropdown-menu ef-topbar__notification-menu">
                <li><h6 class="dropdown-header">{{ 'ui.topbar.notifications'|trans }}</h6></li>

                <li id="ef-notifications-empty"><span class="dropdown-item-text">{{ 'ui.topbar.no_notifications'|trans }}</span></li>

                <li>
                    <a class="dropdown-item d-flex justify-content-between align-items-center" href="{{ path('app_invitations_index') }}">
                        <span><i class="bi bi-envelope-check me-2"></i> {{ 'ui.nav.invitations'|trans }}</span>
                        <span class="badge bg-danger rounded-pill d-none" data-ef-badge="invitations">0</span>
                    </a>
                </li>
                <li>
                    <a class="dropdown-item d-flex justify-content-between align-items-center" href="{{ path('app_messages') }}">
                        <span><i class="bi bi-chat-left me-2"></i> {{ 'ui.nav.messages'|trans }}</span>
                        <span class="badge bg-danger rounded-pill d-none" data-ef-badge="messages">0</span>
                    </a>
                </li>

                <li id="ef-notifications-priority-divider" class="d-none" aria-hidden="true"><hr class="dropdown-divider mb-0"></li>
                <li id="ef-notifications-priority-row" class="d-none">
                    <a id="ef-notifications-priority-link" class="dropdown-item small" href="{{ path('app_messages') }}">
                        {{ 'ui.topbar.view_priority'|trans }}
                    </a>
                </li>
            </ul>
        </div>
        {% endif %}

        <div class="dropdown">
            <button
                class="btn dropdown-toggle border-0 px-2 ef-topbar__theme-btn"
                type="button"
                data-bs-toggle="dropdown"
                aria-expanded="false"
                aria-label="{{ 'ui.topbar.theme'|trans }}"
            >
                <i class="bi bi-sun-fill" id="theme-icon-main" aria-hidden="true"></i>
            </button>

            <ul class="dropdown-menu dropdown-menu-end ef-dropdown-menu ef-topbar__theme-menu">
                <li>
                    <button type="button" class="dropdown-item" data-ef-theme="light">
                        <i class="bi bi-sun-fill me-2" aria-hidden="true"></i> {{ 'ui.topbar.theme_light'|trans }}
                        <i class="bi bi-check2 d-none" aria-hidden="true"></i>
                    </button>
                </li>
                <li>
                    <button type="button" class="dropdown-item" data-ef-theme="dark">
                        <i class="bi bi-moon-stars-fill me-2" aria-hidden="true"></i> {{ 'ui.topbar.theme_dark'|trans }}
                        <i class="bi bi-check2 d-none" aria-hidden="true"></i>
                    </button>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <button type="button" class="dropdown-item" data-ef-theme="auto">
                        <i class="bi bi-circle-half me-2" aria-hidden="true"></i> {{ 'ui.topbar.theme_auto'|trans }}
                        <i class="bi bi-check2 d-none" aria-hidden="true"></i>
                    </button>
                </li>
            </ul>
        </div>
    </div>
</header>
