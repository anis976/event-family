{% use 'bootstrap_5_layout.html.twig' %}

{# Erreurs globales du formulaire (racine) #}
{%- block form_errors -%}
    {%- if errors|length > 0 -%}
        {%- if form is defined and form.parent is null -%}
            <div class="ef-alert ef-alert--danger ef-alert--compact mb-3" role="alert">
                <i class="ef-alert__icon bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
                <div class="ef-alert__content">
                    <strong class="ef-alert__title">{{ 'ui.form.validation.error_title'|trans }}</strong>
                    <ul class="ef-form-errors__list mb-0 small">
                        {%- for error in errors -%}
                            <li>{{ error.message }}</li>
                        {%- endfor -%}
                    </ul>
                </div>
            </div>
        {%- else -%}
            <div class="ef-form-errors invalid-feedback d-block">
                {%- for error in errors -%}
                    <div class="ef-form-errors__item">
                        <i class="bi bi-exclamation-circle-fill" aria-hidden="true"></i>
                        <span>{{ error.message }}</span>
                    </div>
                {%- endfor -%}
            </div>
        {%- endif -%}
    {%- endif -%}
{%- endblock form_errors -%}

{# Bordure rouge sur les champs invalides #}
{%- block form_widget_simple -%}
    {% if errors|default([])|length > 0 %}
        {% set attr = attr|merge({ class: (attr.class|default('') ~ ' is-invalid')|trim }) %}
    {% endif %}
    {{- parent() -}}
{%- endblock form_widget_simple -%}

{%- block textarea_widget -%}
    {% if errors|default([])|length > 0 %}
        {% set attr = attr|merge({ class: (attr.class|default('') ~ ' is-invalid')|trim }) %}
    {% endif %}
    {% set attr = attr|merge({ style: ((attr.style|default('') ~ '; resize: none;')|trim)|trim(';') }) %}
    {{- parent() -}}
{%- endblock textarea_widget -%}

{%- block checkbox_widget -%}
    {% if errors|default([])|length > 0 %}
        {% set attr = attr|merge({ class: (attr.class|default('') ~ ' is-invalid')|trim }) %}
    {% endif %}
    {{- parent() -}}
{%- endblock checkbox_widget -%}
