{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.system_notice.page_title'|trans({'%name%': group.name}) }}{% endblock %}
{% block page_title %}{{ 'admin.system_notice.page_heading'|trans }}{% endblock %}

{% block body %}
<div class="container py-5">
    <nav aria-label="{{ 'admin.system_notice.breadcrumb_aria'|trans }}" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_messages_group', { groupId: group.id }) }}">{{ 'admin.system_notice.breadcrumb_messages'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ group.name }}</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-1">{{ 'admin.system_notice.title'|trans({'%name%': group.name}) }}</h2>
                    <p class="text-muted small mb-4">
                        {{ 'admin.system_notice.hint'|trans }}
                    </p>

                    {{ form_start(form, { attr: { 'data-turbo': 'false' } }) }}
                        {{ form_row(form.content) }}
                        <div class="d-flex flex-wrap gap-2 pt-2">
                            <button type="submit" class="btn btn-save-profile px-4 fw-bold">{{ 'ui.common.save'|trans }}</button>
                            <a href="{{ path('app_messages_group', { groupId: group.id }) }}" class="btn btn-light">{{ 'ui.common.cancel'|trans }}</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
