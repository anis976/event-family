<div class="ef-messages__staff-form p-3 border rounded-4 shadow-sm">
    <p class="ef-messages__staff-form-label mb-2">
        <i class="bi bi-megaphone me-1" aria-hidden="true"></i>
        Annonce officielle EventFamily
        <span class="text-muted fw-normal">— sans réponse possible</span>
    </p>
    {{ form_start(staff_form, {
        action: form_action|default(null),
        attr: { class: 'd-flex align-items-center gap-2', 'data-turbo': 'false' },
    }) }}
        {{ form_widget(staff_form.content, {
            attr: {
                class: 'form-control border-0 shadow-none p-0 bg-transparent',
                placeholder: placeholder|default('Rédiger une annonce pour ce groupe…'),
                rows: '1',
                style: 'resize: none',
            },
        }) }}
        <button type="submit" class="btn ef-messages__staff-send-btn p-0 d-flex align-items-center justify-content-center" aria-label="Publier l'annonce">
            <i class="bi bi-megaphone-fill"></i>
        </button>
    {{ form_end(staff_form) }}
</div>
