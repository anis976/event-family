<div class="ef-messages__send-mode mb-2">
    <p class="small fw-medium mb-1">
        <i class="bi bi-person-badge me-1" aria-hidden="true"></i>
        {{ 'ui.messages.direct.send_as'|trans }}
    </p>
    <div class="d-flex flex-wrap gap-3">
        <div class="form-check">
            <input
                class="form-check-input"
                type="radio"
                name="send_mode"
                id="{{ id_prefix }}-mode-member"
                value="member"
                checked
            >
            <label class="form-check-label small" for="{{ id_prefix }}-mode-member">
                {{ 'ui.messages.direct.mode_member'|trans }}
            </label>
        </div>
        <div class="form-check">
            <input
                class="form-check-input"
                type="radio"
                name="send_mode"
                id="{{ id_prefix }}-mode-moderator"
                value="staff_moderator"
            >
            <label class="form-check-label small" for="{{ id_prefix }}-mode-moderator">
                {{ 'ui.messages.direct.mode_moderator'|trans }}
                <span class="text-muted">{{ 'ui.messages.staff.no_reply'|trans }}</span>
            </label>
        </div>
        {% if is_granted('ROLE_ADMIN') %}
            <div class="form-check">
                <input
                    class="form-check-input"
                    type="radio"
                    name="send_mode"
                    id="{{ id_prefix }}-mode-admin"
                    value="staff_admin"
                >
                <label class="form-check-label small" for="{{ id_prefix }}-mode-admin">
                    {{ 'ui.messages.direct.mode_admin'|trans }}
                    <span class="text-muted">{{ 'ui.messages.staff.no_reply'|trans }}</span>
                </label>
            </div>
        {% endif %}
    </div>
</div>
