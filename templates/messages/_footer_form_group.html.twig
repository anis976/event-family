<div
    class="ef-messages__footer ef-messages__group-compose p-3 bg-white border rounded-4 shadow-sm mt-auto"
    data-ef-max-photos="2"
    data-ef-max-bytes="{{ message_photo_max_bytes|default(3145728) }}"
    data-ef-alert-invalid-format="{{ 'ui.messages.group.photos.alert_invalid_format'|trans|e('html_attr') }}"
    data-ef-alert-max-size="{{ 'ui.messages.group.photos.alert_max_size'|trans|e('html_attr') }}"
    data-ef-alert-max-count="{{ 'ui.messages.group.photos.alert_max_count'|trans|e('html_attr') }}"
    data-ef-alert-cropper-unavailable="{{ 'ui.messages.group.photos.alert_cropper_unavailable'|trans|e('html_attr') }}"
>
    <div class="ef-messages__photo-previews d-flex flex-wrap gap-2 mb-2 d-none" data-ef-photo-previews aria-live="polite"></div>

    {{ form_start(form, {
        action: form_action|default(null),
        attr: {
            class: 'ef-messages__compose-form',
            'data-turbo': 'false',
            enctype: 'multipart/form-data',
        },
    }) }}
        <div class="d-flex align-items-end gap-2">
            <button
                type="button"
                class="btn btn-light btn-sm rounded-circle ef-messages__photo-attach flex-shrink-0"
                data-ef-photo-attach
                aria-label="{{ 'ui.messages.group.photos.attach_aria'|trans }}"
                title="{{ 'ui.messages.group.photos.attach_title'|trans }}"
            >
                <i class="bi bi-image" aria-hidden="true"></i>
            </button>

            <div class="flex-grow-1 min-w-0">
                {{ form_widget(form.content, {
                    attr: {
                        class: 'form-control border-0 shadow-none p-0 bg-transparent',
                        placeholder: placeholder|default('ui.messages.placeholder'|trans),
                        rows: '2',
                        style: 'resize: none',
                        'data-ef-photo-caption': '1',
                    },
                }) }}
            </div>

            <button type="submit" class="btn ef-messages__send-btn p-0 d-flex align-items-center justify-content-center flex-shrink-0" aria-label="{{ 'ui.messages.send_aria'|trans }}">
                <i class="bi bi-send-fill"></i>
            </button>
        </div>

        {% for index in 0..1 %}
            <input type="file" name="photo_{{ index }}" id="ef-group-photo-{{ index }}" class="d-none" accept="image/jpeg,image/png,image/webp" data-ef-photo-input="{{ index }}">
            <input type="hidden" name="photo_{{ index }}_cropX" id="ef-group-photo-{{ index }}-crop-x" value="">
            <input type="hidden" name="photo_{{ index }}_cropY" id="ef-group-photo-{{ index }}-crop-y" value="">
            <input type="hidden" name="photo_{{ index }}_cropWidth" id="ef-group-photo-{{ index }}-crop-w" value="">
            <input type="hidden" name="photo_{{ index }}_cropHeight" id="ef-group-photo-{{ index }}-crop-h" value="">
        {% endfor %}
    {{ form_end(form) }}

    <p class="ef-messages__photo-hint text-muted small mb-0 mt-2">
        <i class="bi bi-info-circle me-1" aria-hidden="true"></i>
        {{ 'ui.messages.group.photos.hint'|trans }}
    </p>
    <p class="ef-messages__photo-privacy-hint text-muted small mb-0 mt-1" role="note">
        <i class="bi bi-shield-exclamation me-1" aria-hidden="true"></i>
        {{ 'ui.messages.group.photos.privacy_hint'|trans }}
    </p>
</div>
