{# Portrait profil : avatar rond si visible, sinon icône par défaut #}
{% set subject = profileUser|default(null) %}
{% if subject and profile_avatar_visible(subject) %}
    <div class="ef-profile-avatar-wrap me-3">
        <img
            src="{{ path('app_profile_avatar_show', { id: subject.id, v: subject.updatedAt.timestamp }) }}"
            alt="Photo de {{ subject.displayName }}"
            class="ef-profile-avatar"
            loading="lazy"
            decoding="async"
        >
    </div>
{% else %}
    <div class="ef-profile-avatar-fallback me-3" aria-hidden="true">
        <i class="bi bi-person-fill" aria-hidden="true"></i>
    </div>
{% endif %}
