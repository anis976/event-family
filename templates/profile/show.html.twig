{% extends 'base.html.twig' %}

{% block title %}EventFamily — Profil de {{ profileUser.firstName|capitalize }}{% endblock %}

{% block page_title %}Profil membre{% endblock %}

{% block body %}
    <section class="ef-profile-section py-3 py-lg-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-md-10 col-lg-8">
                    {% include 'profile/_header.html.twig' with {
                        title: 'Profil de membre',
                        subtitle: 'Consultation des informations du cercle',
                        profileUser: profileUser,
                    } only %}

                    <div class="card ef-profile-card border-0 shadow-sm">
                        <div class="card-body p-3 p-md-4">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold text-uppercase opacity-50">Nom d'utilisateur</label>
                                    <div class="form-control-plaintext ps-2 fw-medium">
                                        {% if profileUser.pseudo %}
                                            @{{ profileUser.pseudo }}
                                        {% else %}
                                            <span class="text-muted">Non renseigné</span>
                                        {% endif %}
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label small fw-bold text-uppercase opacity-50">Prénom &amp; nom</label>
                                    <div class="form-control-plaintext ps-2 fw-medium">
                                        {{ profileUser.firstName|capitalize }} {{ profileUser.lastName|upper }}
                                    </div>
                                </div>

                                <div class="col-12"><hr class="my-2 opacity-50"></div>

                                <div class="col-md-6">
                                    <label class="form-label small fw-bold text-uppercase opacity-50">Membre depuis</label>
                                    <div class="form-control-plaintext ps-2 fw-medium">
                                        {{ profileUser.createdAt|date('d/m/Y') }}
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label small fw-bold text-uppercase opacity-50">Nom affiché</label>
                                    <div class="form-control-plaintext ps-2 fw-medium">{{ profileUser.displayName }}</div>
                                </div>

                                {% if app.user %}
                                    <div class="col-12 mt-4">
                                        {% if canSendMessage %}
                                            <div id="btn-container-msg">
                                                <button
                                                    type="button"
                                                    class="btn btn-message-profile w-100 py-2 fw-bold shadow-sm"
                                                    id="btn-open-msg"
                                                    data-bs-toggle="collapse"
                                                    data-bs-target="#form-msg-profile"
                                                    aria-expanded="false"
                                                    aria-controls="form-msg-profile"
                                                >
                                                    <i class="bi bi-chat-dots me-2" aria-hidden="true"></i>
                                                    Envoyer un message privé
                                                </button>
                                            </div>

                                            <div class="collapse mt-3" id="form-msg-profile">
                                                <form
                                                    action="{{ path('app_messages_send_direct') }}"
                                                    method="post"
                                                    class="p-3 border rounded-3 shadow-sm ef-profile__message-form"
                                                    data-turbo="false"
                                                >
                                                    <input type="hidden" name="_token" value="{{ csrf_token('send_direct_message') }}">
                                                    <input type="hidden" name="recipient_id" value="{{ profileUser.id }}">

                                                    <textarea
                                                        name="content"
                                                        class="form-control ef-input rounded-4 mb-3"
                                                        rows="3"
                                                        style="resize: none;"
                                                        placeholder="Écris ton message privé à {{ profileUser.firstName|capitalize }}…"
                                                        required
                                                    ></textarea>

                                                    <div class="d-flex justify-content-end gap-2">
                                                        <button
                                                            type="button"
                                                            class="btn btn-sm btn-outline-secondary"
                                                            data-bs-toggle="collapse"
                                                            data-bs-target="#form-msg-profile"
                                                            data-ef-msg-cancel
                                                        >
                                                            Annuler
                                                        </button>
                                                        <button type="submit" class="btn btn-sm btn-save-profile">
                                                            Envoyer maintenant
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        {% else %}
                                            <div class="alert alert-warning small mb-0" role="alert">
                                                <i class="bi bi-slash-circle me-1" aria-hidden="true"></i>
                                                {{ messageDenialReason }}
                                            </div>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if canSendMessage %}
        <script src="{{ asset('js/ef-profile-message.js') }}" defer></script>
    {% endif %}
{% endblock %}
