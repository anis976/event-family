{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.profile.show.page_title'|trans({'%name%': profileUser.firstName|capitalize}) }}{% endblock %}

{% block page_title %}{{ 'ui.profile.show.page_heading'|trans }}{% endblock %}

{% block body %}
    <section class="ef-profile-section py-3 py-lg-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-md-10 col-lg-8">
                    {% include 'profile/_header.html.twig' with {
                        title: 'ui.profile.show.title'|trans,
                        subtitle: 'ui.profile.show.subtitle'|trans,
                        profileUser: profileUser,
                    } only %}

                    <div class="card ef-profile-card border-0 shadow-sm">
                        <div class="card-body p-3 p-md-4">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <span class="d-block form-label small fw-bold text-uppercase opacity-50">{{ 'ui.profile.username'|trans }}</span>
                                    <div class="form-control-plaintext ps-2 fw-medium">
                                        {% if profileUser.pseudo %}
                                            @{{ profileUser.pseudo }}
                                        {% else %}
                                            <span class="text-muted">{{ 'ui.profile.show.not_set'|trans }}</span>
                                        {% endif %}
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <span class="d-block form-label small fw-bold text-uppercase opacity-50">{{ 'ui.profile.show.full_name'|trans }}</span>
                                    <div class="form-control-plaintext ps-2 fw-medium">
                                        {{ profileUser.firstName|capitalize }} {{ profileUser.lastName|upper }}
                                    </div>
                                </div>

                                <div class="col-12"><hr class="my-2 opacity-50"></div>

                                <div class="col-md-6">
                                    <span class="d-block form-label small fw-bold text-uppercase opacity-50">{{ 'ui.profile.show.member_since'|trans }}</span>
                                    <div class="form-control-plaintext ps-2 fw-medium">
                                        {{ profileUser.createdAt|ef_date }}
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <span class="d-block form-label small fw-bold text-uppercase opacity-50">{{ 'ui.profile.show.display_name'|trans }}</span>
                                    <div class="form-control-plaintext ps-2 fw-medium">{{ profileUser.displayName }}</div>
                                </div>

                                {% if app.user %}
                                    <div class="col-12 mt-4">
                                        {% if canSendMessage %}
                                            <div id="btn-container-msg">
                                                <button
                                                    type="button"
                                                    class="btn btn-message-profile w-100 py-2 fw-bold shadow-sm"
                                                    id="btn-open-msg"
                                                    data-bs-toggle="collapse"
                                                    data-bs-target="#form-msg-profile"
                                                    aria-expanded="false"
                                                    aria-controls="form-msg-profile"
                                                >
                                                    <i class="bi bi-chat-dots me-2" aria-hidden="true"></i>
                                                    {{ 'ui.profile.show.send_private'|trans }}
                                                </button>
                                            </div>

                                            <div class="collapse mt-3" id="form-msg-profile">
                                                <form
                                                    action="{{ path('app_messages_send_direct') }}"
                                                    method="post"
                                                    class="p-3 border rounded-3 shadow-sm ef-profile__message-form"
                                                    data-turbo="false"
                                                >
                                                    <input type="hidden" name="_token" value="{{ csrf_token('send_direct_message') }}">
                                                    <input type="hidden" name="recipient_id" value="{{ profileUser.id }}">

                                                    {% if ef_is_site_staff %}
                                                        {% include 'messages/_direct_message_send_mode.html.twig' with {
                                                            id_prefix: 'profile-msg-' ~ profileUser.id,
                                                        } only %}
                                                    {% endif %}

                                                    <textarea
                                                        id="profile-msg-content"
                                                        name="content"
                                                        class="form-control ef-input rounded-4 mb-3"
                                                        rows="3"
                                                        placeholder="{{ 'ui.profile.show.message_placeholder'|trans({'%name%': profileUser.firstName|capitalize}) }}"
                                                        aria-label="{{ 'ui.profile.show.message_label'|trans({'%name%': profileUser.firstName|capitalize}) }}"
                                                        required
                                                    ></textarea>

                                                    <div class="d-flex justify-content-end gap-2">
                                                        <button
                                                            type="button"
                                                            class="btn btn-sm btn-outline-secondary"
                                                            data-bs-toggle="collapse"
                                                            data-bs-target="#form-msg-profile"
                                                            data-ef-msg-cancel
                                                        >
                                                            {{ 'ui.common.cancel'|trans }}
                                                        </button>
                                                        <button type="submit" class="btn btn-sm btn-save-profile">
                                                            {{ 'ui.profile.show.send_now'|trans }}
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        {% else %}
                                            <div class="alert alert-warning small mb-0" role="alert">
                                                <i class="bi bi-slash-circle me-1" aria-hidden="true"></i>
                                                {{ messageDenialReason|trans }}
                                            </div>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
