<div
    class="ef-profile-avatar-manager mb-4"
    data-ef-alert-invalid-format="{{ 'ui.profile.avatar.alert_invalid_format'|trans|e('html_attr') }}"
    data-ef-alert-max-size="{{ 'ui.profile.avatar.alert_max_size'|trans|e('html_attr') }}"
    data-ef-alert-cropper-unavailable="{{ 'ui.profile.avatar.alert_cropper_unavailable'|trans|e('html_attr') }}"
    data-ef-alert-upload-failed="{{ 'ui.profile.avatar.alert_upload_failed'|trans|e('html_attr') }}"
>
    <h2 class="h6 small fw-bold text-uppercase opacity-50 mb-2">
        {{ 'ui.profile.avatar.label'|trans }} <span class="text-muted fw-normal">{{ 'ui.profile.avatar.optional'|trans }}</span>
    </h2>

    <div class="d-flex flex-column flex-sm-row align-items-start gap-3 p-3 border rounded-3 bg-light-subtle">
        <div class="ef-profile-avatar-manager__preview-wrap">
            {% if profile_avatar_visible(user) %}
                <div class="ef-profile-avatar-wrap ef-profile-avatar-wrap--preview">
                    <img
                        src="{{ path('app_profile_avatar_show', { id: user.id, v: user.updatedAt.timestamp }) }}"
                        alt="{{ 'ui.profile.avatar.alt_self'|trans }}"
                        class="ef-profile-avatar"
                    >
                </div>
            {% else %}
                <div class="ef-profile-avatar-fallback ef-profile-avatar-wrap--preview" aria-hidden="true">
                    <i class="bi bi-person-fill" aria-hidden="true"></i>
                </div>
            {% endif %}
        </div>

        <div class="flex-grow-1">
            <p class="small text-muted mb-3">
                {{ 'ui.profile.avatar.hint'|trans }}
                {% if user.hasAvatar %}
                    {% if user.avatarVisibility.value == 'private' %}
                        <span class="d-block mt-1">{{ 'ui.profile.avatar.visibility_private'|trans }}</span>
                    {% else %}
                        <span class="d-block mt-1">{{ 'ui.profile.avatar.visibility_public'|trans }}</span>
                    {% endif %}
                {% endif %}
            </p>

            <div class="d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" id="ef-avatar-choose-btn">
                    <i class="bi bi-camera me-1" aria-hidden="true"></i>
                    {{ user.hasAvatar ? 'ui.profile.avatar.change'|trans : 'ui.profile.avatar.add'|trans }}
                </button>

                {% if user.hasAvatar %}
                    <form action="{{ path('app_profile_avatar_delete') }}" method="post" data-turbo="false" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('profile_avatar_delete') }}">
                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('{{ 'ui.profile.avatar.delete_confirm'|trans|e('js') }}');">
                            <i class="bi bi-trash me-1" aria-hidden="true"></i>
                            {{ 'ui.common.delete'|trans }}
                        </button>
                    </form>
                {% endif %}
            </div>

            <input
                type="file"
                id="ef-avatar-file-input"
                class="d-none"
                accept="image/jpeg,image/png,image/webp"
            >
        </div>
    </div>
</div>

<form
    id="ef-avatar-upload-form"
    action="{{ path('app_profile_avatar_upload') }}"
    method="post"
    enctype="multipart/form-data"
    data-turbo="false"
    class="d-none"
>
    <input type="hidden" name="_token" value="{{ csrf_token('profile_avatar_upload') }}">
    <input type="hidden" name="cropX" id="ef-avatar-crop-x">
    <input type="hidden" name="cropY" id="ef-avatar-crop-y">
    <input type="hidden" name="cropWidth" id="ef-avatar-crop-w">
    <input type="hidden" name="cropHeight" id="ef-avatar-crop-h">
    <input type="hidden" name="visibility" id="ef-avatar-visibility" value="private">
</form>

<div class="modal fade" id="ef-avatar-crop-modal" tabindex="-1" aria-labelledby="ef-avatar-crop-modal-label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="ef-avatar-crop-modal-label">{{ 'ui.profile.avatar.crop_title'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'ui.common.close'|trans }}"></button>
            </div>
            <div class="modal-body">
                <div class="ef-profile-avatar-manager__crop-area mb-3">
                    <img id="ef-avatar-crop-image" src="" alt="" role="presentation" class="w-100">
                </div>

                <fieldset class="border-0 p-0 m-0">
                    <legend class="form-label fw-medium fs-6 mb-2">{{ 'ui.profile.avatar.visibility_question'|trans }}</legend>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="ef_avatar_visibility_choice" id="ef-avatar-vis-public" value="public">
                        <label class="form-check-label" for="ef-avatar-vis-public">
                            {{ 'ui.profile.avatar.visibility_public_label'|trans }}
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="ef_avatar_visibility_choice" id="ef-avatar-vis-private" value="private" checked>
                        <label class="form-check-label" for="ef-avatar-vis-private">
                            {{ 'ui.profile.avatar.visibility_private_label'|trans }}
                        </label>
                    </div>
                </fieldset>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">{{ 'ui.common.cancel'|trans }}</button>
                <button type="button" class="btn btn-save-profile" id="ef-avatar-crop-save">
                    <i class="bi bi-check-lg me-1" aria-hidden="true"></i>
                    {{ 'ui.common.save'|trans }}
                </button>
            </div>
        </div>
    </div>
</div>
