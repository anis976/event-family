{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.profile.delete_blocked.page_title'|trans }}{% endblock %}

{% block page_title %}{{ 'ui.profile.delete_account.page_heading'|trans }}{% endblock %}

{% block body %}
    <section class="ef-profile-section py-3 py-lg-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-md-8 col-lg-6">
                    <div class="card ef-profile-card border-0 shadow-sm">
                        <div class="card-body p-4 p-md-5">
                            <h1 class="h5 text-danger fw-bold mb-3">{{ 'ui.profile.delete_blocked.heading'|trans }}</h1>
                            <p class="mb-3">
                                {{ 'ui.profile.delete_blocked.intro'|trans }}
                            </p>
                            <ul class="small text-muted mb-4">
                                <li>{{ 'ui.profile.delete_blocked.option_successor'|trans }}</li>
                                <li>{{ 'ui.profile.delete_blocked.option_delete'|trans }}</li>
                            </ul>
                            <p class="small text-muted mb-4">
                                {{ 'ui.profile.delete_blocked.coming_soon'|trans }}
                            </p>
                            <a href="{{ path('app_profile') }}" class="btn btn-save-profile w-100 py-2 fw-bold">
                                {{ 'ui.profile.delete_blocked.back'|trans }}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
