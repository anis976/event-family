{% extends 'base.html.twig' %}

{% block title %}EventFamily — Modifier mon mot de passe{% endblock %}

{% block page_title %}Sécurité du compte{% endblock %}

{% block body %}
    <section class="ef-profile-section py-3 py-lg-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-md-8 col-lg-6">
                    <div class="card ef-profile-card border-0 shadow-sm">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-4">
                                <a href="{{ path('app_profile') }}" class="btn btn-outline-secondary btn-sm me-3">
                                    <i class="bi bi-arrow-left" aria-hidden="true"></i>
                                    <span class="visually-hidden">Retour</span>
                                </a>
                                <h2 class="h4 mb-0">Sécurité du compte</h2>
                            </div>

                            <p class="text-muted small mb-4">
                                Choisis un mot de passe robuste (au moins 8 caractères). Un e-mail de confirmation te sera envoyé&nbsp;: le changement ne sera effectif qu'après clic sur le lien. Si ce n'est pas toi, ignore simplement le message.
                            </p>

                            {% include 'components/_ef_form_validation_summary.html.twig' with { form: passwordForm } only %}

                            {{ form_start(passwordForm, { attr: { class: 'ef-profile__password-form' } }) }}

                            <div class="mb-3">
                                {{ form_label(passwordForm.currentPassword, null, { label_attr: { class: 'form-label fw-bold' } }) }}
                                {{ form_widget(passwordForm.currentPassword) }}
                                {{ form_errors(passwordForm.currentPassword) }}
                            </div>

                            <hr class="my-4 text-muted opacity-50">

                            <div class="mb-3">
                                {{ form_label(passwordForm.newPassword.first, null, { label_attr: { class: 'form-label fw-bold' } }) }}
                                {{ form_widget(passwordForm.newPassword.first) }}
                                {{ form_errors(passwordForm.newPassword.first) }}
                            </div>

                            <div class="mb-3">
                                {{ form_label(passwordForm.newPassword.second, null, { label_attr: { class: 'form-label fw-bold' } }) }}
                                {{ form_widget(passwordForm.newPassword.second) }}
                                {{ form_errors(passwordForm.newPassword.second) }}
                            </div>

                            {{ form_errors(passwordForm.newPassword) }}

                            <button type="submit" class="btn btn-save-profile w-100 mt-3 py-2 fw-bold shadow-sm">
                                <i class="bi bi-shield-lock-fill me-2" aria-hidden="true"></i>
                                Mettre à jour mon mot de passe
                            </button>

                            {{ form_end(passwordForm) }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
