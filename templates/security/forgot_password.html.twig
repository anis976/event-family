{% extends 'layout/auth.html.twig' %}

{% block title %}{{ 'ui.auth.forgot.page_title'|trans }}{% endblock %}

{% block body_class %} ef-signIn{% endblock %}

{% block auth_flash %}{% endblock %}

{% block body %}
    <div class="container-fluid ef-main-wrapper">
        <div class="container">
            <div class="row align-items-center justify-content-center g-4">
                <div class="col-12 col-md-7 col-lg-5 col-xl-5 ef-signIn__column">
                    <div class="ef-signIn__alerts">
                        {% include 'components/_ef_flash_messages.html.twig' %}
                    </div>

                    <form
                        method="post"
                        class="card shadow-lg p-4 p-sm-5 ef-auth__form-card"
                        data-turbo="false"
                    >
                        <h1 class="text-center fw-bold mb-3 mt-0 h2">{{ 'ui.auth.forgot.title'|trans }}</h1>

                        <p class="text-muted small text-center mb-4">
                            {{ 'ui.auth.forgot.hint'|trans }}
                        </p>

                        {% include 'components/_ef_form_validation_summary.html.twig' with { form: forgotPasswordForm } only %}

                        {{ form_start(forgotPasswordForm) }}

                        <div class="mb-4">
                            {{ form_label(forgotPasswordForm.email, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                            {{ form_widget(forgotPasswordForm.email) }}
                            {{ form_errors(forgotPasswordForm.email) }}
                        </div>

                        <button type="submit" class="btn btn-submit-custom btn-lg w-100 mb-3 fw-bold">
                            {{ 'ui.auth.forgot.submit'|trans }}
                        </button>

                        {{ form_end(forgotPasswordForm) }}

                        <p class="text-center mb-0 small">
                            <a href="{{ path('app_login') }}" class="ef-link-orange fw-bold text-decoration-none">
                                <i class="bi bi-arrow-left me-1" aria-hidden="true"></i>
                                {{ 'ui.auth.forgot.back_to_login'|trans }}
                            </a>
                        </p>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
