{% extends 'layout/auth.html.twig' %}

{% block title %}EventFamily — Nouveau mot de passe{% endblock %}

{% block body_class %} ef-signIn{% endblock %}

{% block auth_flash %}{% endblock %}

{% block body %}
    <div class="container-fluid ef-main-wrapper ef-signIn">
        <div class="container">
            <div class="row align-items-center justify-content-center g-4">
                <div class="col-12 col-md-7 col-lg-5 col-xl-5 ef-signIn__column">
                    <div class="ef-signIn__alerts">
                        {% include 'components/_ef_flash_messages.html.twig' %}
                    </div>

                    <form
                        method="post"
                        class="card shadow-lg p-4 p-sm-5 ef-auth__form-card"
                        data-turbo="false"
                    >
                        <h1 class="text-center fw-bold mb-3 mt-0 h2">Nouveau mot de passe</h1>

                        <p class="text-muted small text-center mb-4">
                            Choisis un mot de passe robuste (au moins 8 caractères). Ce lien est à usage unique.
                        </p>

                        {% include 'components/_ef_form_validation_summary.html.twig' with { form: resetPasswordForm } only %}

                        {{ form_start(resetPasswordForm) }}

                        <div class="mb-3">
                            {{ form_label(resetPasswordForm.plainPassword.first, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                            {{ form_widget(resetPasswordForm.plainPassword.first) }}
                            {{ form_errors(resetPasswordForm.plainPassword.first) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(resetPasswordForm.plainPassword.second, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                            {{ form_widget(resetPasswordForm.plainPassword.second) }}
                            {{ form_errors(resetPasswordForm.plainPassword.second) }}
                        </div>

                        {{ form_errors(resetPasswordForm.plainPassword) }}

                        <button type="submit" class="btn btn-submit-custom btn-lg w-100 mb-3 fw-bold">
                            Enregistrer le mot de passe
                        </button>

                        {{ form_end(resetPasswordForm) }}
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
