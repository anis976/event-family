<!DOCTYPE html>
<html lang="{{ app.request.locale }}" data-bs-theme="light" data-ef-consent-choice="{{ ef_consent.hasChoice ? '1' : '0' }}" data-ef-consent-marketing="{{ ef_consent.marketing ? '1' : '0' }}" data-ef-consent-analytics="{{ ef_consent.analytics ? '1' : '0' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    {# Évite d’afficher un aperçu en cache pendant le chargement (effet « retour en arrière ») #}
    <meta name="turbo-cache-control" content="no-preview">
    <title>{% block title %}RapporFam{% endblock %}</title>
    {% block meta_description %}{% endblock %}
    {% block meta_og %}{% endblock %}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>📅</text></svg>">

    <script src="{{ asset('js/ef-theme-init.js') }}"></script>
    {% include 'components/_ef_theme_critical.html.twig' %}

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
        crossorigin="anonymous"
    >
    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    >

    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.scss') }}">
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}

    {# Chargé une seule fois dans <head> : évite les instances Bootstrap cassées après Turbo #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous" defer></script>

    {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
    {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
    {% endif %}

    {% include 'components/_ef_adsense_head.html.twig' %}
</head>
<body class="ef-body{% block body_class %}{% endblock %}"{% if app.user %}
    data-ef-counts-url="{{ path('app_invitations_counts') }}"
    data-ef-notification-aria="{{ 'ui.topbar.notifications'|trans }}"
    data-ef-notification-pending-aria="{{ 'ui.topbar.notifications_pending'|trans }}"
    data-ef-session-idle="{{ ef_session_idle_timeout }}"
    data-ef-session-warning="{{ ef_session_idle_warning }}"
{% endif %}>
    {% include 'components/_ef_cookie_consent.html.twig' %}

    <div class="ef-main-wrapper d-flex">
        {% include 'layout/_sidebar.html.twig' %}

        <div class="ef-main">
            {% include 'layout/_topbar.html.twig' with { page_title: block('page_title')|default('ui.nav.home'|trans) } %}
            {% if app.user %}
                {% include 'layout/_search_panel.html.twig' %}
            {% endif %}

            <div class="ef-main__flash container-fluid px-4 pt-3">
                {% include 'components/_ef_flash_messages.html.twig' %}
            </div>

            {% block body %}{% endblock %}

            {% block footer %}
                {% include 'layout/_footer.html.twig' %}
            {% endblock %}
        </div>
    </div>

    <button type="button" id="backToTop" class="ef-btn-back-to-top shadow" aria-label="{{ 'ui.common.back_to_top'|trans }}">
        <i class="bi bi-arrow-up" aria-hidden="true"></i>
    </button>

    <button type="button" id="sidebarOverlay" class="ef-sidebar-overlay" aria-label="{{ 'ui.sidebar.close_menu'|trans }}"></button>

    {% if app.user %}
        {% include 'components/_session_idle_modal.html.twig' %}
        <form id="ef-session-logout-form" action="{{ path('app_logout') }}" method="post" data-turbo="false" class="d-none" aria-hidden="true">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
            <input type="hidden" name="_idle" value="1">
        </form>
        <form id="ef-session-activity-form" action="{{ path('app_session_activity') }}" method="post" data-turbo="false" class="d-none" aria-hidden="true">
            <input type="hidden" name="_token" value="{{ csrf_token('session_activity') }}">
        </form>
    {% endif %}
</body>
</html>
